---
import { getTranslations } from "@/i18n";
import type { Locale } from "@/i18n/config";

interface Props {
  trustPoints: string[];
}

const { trustPoints } = Astro.props;
const locale = (Astro.currentLocale ?? "fr") as Locale;
const t = getTranslations(locale);
---

<section class="px-4 py-5 sm:px-6 lg:px-10">
  <div class="panel mx-auto max-w-7xl rounded-full border border-white/60 px-6 py-4">
    <div class="flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between">
      <p class="eyebrow shrink-0 whitespace-nowrap">{t.sections.trustBar.label}</p>
      <div class="flex flex-wrap gap-x-6 gap-y-2 text-sm uppercase tracking-[0.18em] text-charcoal/62 lg:justify-end">
        {trustPoints.map((point) => <span class="max-w-[24ch] leading-snug">{point}</span>)}
      </div>
    </div>
  </div>
</section>
