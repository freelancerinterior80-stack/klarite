---
import { client } from "@/sanity/client";
import { getTranslations } from "@/i18n";
import type { Locale } from "@/i18n/config";

const locale = (Astro.currentLocale ?? "fr") as Locale;
const t = getTranslations(locale);

const raw = await client.fetch(
  `*[_id == "footerSettings"][0]{
    "brandTagline":   coalesce(brandTagline[_key == $locale][0].value,   brandTagline[_key == "fr"][0].value),
    "brandCopy":      coalesce(brandCopy[_key == $locale][0].value,      brandCopy[_key == "fr"][0].value),
    email,
    "contactHours":   coalesce(contactHours[_key == $locale][0].value,   contactHours[_key == "fr"][0].value),
    "contactTagline": coalesce(contactTagline[_key == $locale][0].value, contactTagline[_key == "fr"][0].value),
    copyrightText,
    privacyUrl,
    termsUrl,
    shippingUrl,
    instagramUrl,
    tiktokUrl,
    facebookUrl,
  }`,
  { locale }
);

const footer = {
  brandTagline:   raw?.brandTagline   || t.footer.brandTagline,
  brandCopy:      raw?.brandCopy      || t.footer.brandCopy,
  email:          raw?.email          || "bonjour@klarite.com",
  contactHours:   raw?.contactHours   || t.footer.contactHours,
  contactTagline: raw?.contactTagline || t.footer.contactTagline,
  copyrightText:  raw?.copyrightText  || t.footer.copyright,
  privacyUrl:     raw?.privacyUrl     || null,
  termsUrl:       raw?.termsUrl       || null,
  shippingUrl:    raw?.shippingUrl    || null,
  instagramUrl:   raw?.instagramUrl   || null,
  tiktokUrl:      raw?.tiktokUrl      || null,
  facebookUrl:    raw?.facebookUrl    || null,
};

const socialLinks = [
  {
    url:   footer.instagramUrl,
    label: "Instagram",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>`,
  },
  {
    url:   footer.tiktokUrl,
    label: "TikTok",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.27 6.27 0 0 0-.79-.05 6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34V8.69a8.27 8.27 0 0 0 4.84 1.54V6.78a4.85 4.85 0 0 1-1.07-.09z"/></svg>`,
  },
  {
    url:   footer.facebookUrl,
    label: "Facebook",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>`,
  },
].filter(s => s.url);
---

<footer class="px-4 pb-8 pt-12 sm:px-6 lg:px-10">
  <div class="mx-auto grid max-w-[90rem] gap-10 border-t border-charcoal/10 py-12 lg:grid-cols-[1.2fr_0.8fr_0.8fr]">

    <!-- Brand column -->
    <div>
      <p class="eyebrow mb-4">KLARITE</p>
      <h2 class="section-title text-3xl text-charcoal sm:text-4xl">{footer.brandTagline}</h2>
      <p class="mt-4 max-w-xl text-sm leading-7 text-charcoal/66 sm:text-base">
        {footer.brandCopy}
      </p>
      {socialLinks.length > 0 && (
        <div class="mt-6 flex items-center gap-3">
          {socialLinks.map(({ url, label, icon }) => (
            <a
              href={url!}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={label}
              class="flex h-9 w-9 items-center justify-center rounded-full border border-charcoal/12 text-charcoal/50 transition-all duration-300 hover:border-charcoal/30 hover:text-charcoal hover:-translate-y-0.5"
              set:html={icon}
            />
          ))}
        </div>
      )}
    </div>

    <!-- Explore column -->
    <div>
      <h3 class="text-sm uppercase tracking-[0.24em] text-charcoal/62">{t.footer.exploreTitle}</h3>
      <div class="mt-4 flex flex-col gap-3 text-sm text-charcoal/72">
        <a href="#signature-products" class="transition hover:text-charcoal">{t.footer.nav.products}</a>
        <a href="#benefits"           class="transition hover:text-charcoal">{t.footer.nav.benefits}</a>
        <a href="#collection-grid"    class="transition hover:text-charcoal">{t.footer.nav.collection}</a>
        <a href="#rituals"            class="transition hover:text-charcoal">{t.footer.nav.ritual}</a>
      </div>
    </div>

    <!-- Contact column -->
    <div>
      <h3 class="text-sm uppercase tracking-[0.24em] text-charcoal/62">{t.footer.contactTitle}</h3>
      <div class="mt-4 space-y-3 text-sm leading-7 text-charcoal/68">
        <p>
          <a href={`mailto:${footer.email}`} class="transition hover:text-charcoal">{footer.email}</a>
        </p>
        {footer.contactHours   && <p>{footer.contactHours}</p>}
        {footer.contactTagline && <p>{footer.contactTagline}</p>}
      </div>
    </div>
  </div>

  <!-- Legal bar -->
  <div class="mx-auto flex max-w-[90rem] flex-col items-center justify-between gap-4 border-t border-charcoal/8 pt-6 text-[0.68rem] uppercase tracking-[0.22em] text-charcoal/40 sm:flex-row">
    <p>{footer.copyrightText}</p>
    <div class="flex gap-5">
      {footer.privacyUrl  && <a href={footer.privacyUrl}  class="transition hover:text-charcoal/70">{t.footer.legal.privacy}</a>}
      {footer.termsUrl    && <a href={footer.termsUrl}    class="transition hover:text-charcoal/70">{t.footer.legal.terms}</a>}
      {footer.shippingUrl && <a href={footer.shippingUrl} class="transition hover:text-charcoal/70">{t.footer.legal.shipping}</a>}
    </div>
    <p>
      Developed by&nbsp;
      <a
        href="https://www.ticodetech.com"
        target="_blank"
        rel="noopener noreferrer"
        class="transition hover:text-charcoal/70"
      >
        Ticode Technologies
      </a>
    </p>
  </div>
</footer>
