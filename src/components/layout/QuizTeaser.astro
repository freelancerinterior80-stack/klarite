---
import LinkButton from "@/components/ui/LinkButton.astro";
import { getTranslations } from "@/i18n";
import type { Locale } from "@/i18n/config";

const locale = (Astro.currentLocale ?? "fr") as Locale;
const t = getTranslations(locale);
---

<section id="quiz" class="px-4 py-20 sm:px-6 lg:px-10">
  <div class="mx-auto grid max-w-7xl gap-5 lg:grid-cols-[1fr_0.95fr]">
    <article class="ambient-card rounded-[2.4rem] border border-white/70 p-8 shadow-[0_24px_70px_rgba(31,37,34,0.08)]" data-reveal>
      <p class="eyebrow">{t.sections.quiz.eyebrow}</p>
      <h2 class="section-title mt-4 text-4xl text-charcoal sm:text-5xl">
        {t.sections.quiz.title}
      </h2>
      <p class="mt-5 max-w-2xl text-base leading-8 text-charcoal/72">
        {t.sections.quiz.description}
      </p>
      <div class="mt-8 flex flex-col gap-3 sm:flex-row">
        <LinkButton href="#newsletter">{t.sections.quiz.ctaPrimary}</LinkButton>
        <LinkButton href="#concerns" variant="ghost">{t.sections.quiz.ctaSecondary}</LinkButton>
      </div>
    </article>

    <article class="asset-well rounded-[2.4rem] px-8 py-8" data-reveal>
      <div class="relative z-10 flex h-full flex-col justify-between">
        <p class="eyebrow">Data Capture Strategy</p>
        <div class="space-y-5">
          <div class="rounded-[1.5rem] border border-white/60 bg-white/44 px-5 py-4">
            <p class="text-sm uppercase tracking-[0.2em] text-charcoal/58">{t.sections.quiz.q1Label}</p>
            <p class="mt-2 font-display text-2xl text-charcoal">{t.sections.quiz.q1}</p>
          </div>
          <div class="rounded-[1.5rem] border border-white/60 bg-white/44 px-5 py-4">
            <p class="text-sm uppercase tracking-[0.2em] text-charcoal/58">{t.sections.quiz.q2Label}</p>
            <p class="mt-2 font-display text-2xl text-charcoal">{t.sections.quiz.q2}</p>
          </div>
          <div class="rounded-[1.5rem] border border-white/60 bg-white/44 px-5 py-4">
            <p class="text-sm uppercase tracking-[0.2em] text-charcoal/58">{t.sections.quiz.q3Label}</p>
            <p class="mt-2 font-display text-2xl text-charcoal">{t.sections.quiz.q3}</p>
          </div>
        </div>
      </div>
    </article>
  </div>
</section>
