---
const navItems = [
  { href: "#signature-products", label: "Signature" },
  { href: "#benefits", label: "Benefits" },
  { href: "#collection-grid", label: "Collection" },
  { href: "#rituals", label: "Ritual" },
  { href: "#testimonials", label: "Testimonials" }
];
---

<header class="sticky top-0 z-50 px-4 pt-4 sm:px-6 lg:px-10">
  <div class="mx-auto flex max-w-[90rem] items-center justify-between rounded-full border border-white/70 bg-white/52 px-4 py-3 shadow-[0_20px_50px_rgba(26,26,26,0.06)] backdrop-blur-xl sm:px-6">
    <a href="/" class="flex items-center gap-3">
      <span class="font-display text-[1.5rem] tracking-[0.24em] text-charcoal">KLARITE</span>
      <span class="hidden text-[0.68rem] uppercase tracking-[0.34em] text-charcoal/42 sm:block">
        Toucher Doux
      </span>
    </a>

    <nav class="hidden items-center gap-7 lg:flex">
      {
        navItems.map((item) => (
          <a
            href={item.href}
            class="text-[0.72rem] uppercase tracking-[0.26em] text-charcoal/58 transition hover:text-charcoal"
          >
            {item.label}
          </a>
        ))
      }
    </nav>

    <div class="hidden items-center gap-3 lg:flex">
      <a
        href="#skin-quiz"
        class="rounded-full border border-charcoal/10 px-4 py-2 text-[0.72rem] uppercase tracking-[0.24em] text-charcoal/68 transition hover:border-gold/35 hover:text-charcoal"
      >
        Skin Quiz
      </a>
      <a
        href="#signature-products"
        class="rounded-full border border-gold/50 bg-charcoal px-5 py-2.5 text-[0.72rem] uppercase tracking-[0.24em] text-cream transition hover:-translate-y-0.5 hover:bg-[#111111]"
      >
        Shop Collection
      </a>
    </div>

    <details class="group relative lg:hidden">
      <summary class="list-none rounded-full border border-charcoal/12 px-4 py-2 text-[0.68rem] uppercase tracking-[0.24em] text-charcoal/72">
        Menu
      </summary>
      <div class="absolute right-0 top-16 w-[min(22rem,calc(100vw-2rem))] rounded-[1.8rem] border border-white/75 bg-white/90 p-6 shadow-[0_24px_60px_rgba(26,26,26,0.12)] backdrop-blur-xl">
        <nav class="flex flex-col gap-4">
          {
            navItems.map((item) => (
              <a href={item.href} class="border-b border-charcoal/8 pb-4 text-sm uppercase tracking-[0.22em] text-charcoal/72 last:border-none last:pb-0">
                {item.label}
              </a>
            ))
          }
        </nav>
      </div>
    </details>
  </div>
</header>
