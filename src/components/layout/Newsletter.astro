---
import LinkButton from "@/components/ui/LinkButton.astro";
import { getTranslations } from "@/i18n";
import type { Locale } from "@/i18n/config";

const locale = (Astro.currentLocale ?? "fr") as Locale;
const t = getTranslations(locale);
---

<section id="newsletter" class="px-4 py-20 sm:px-6 lg:px-10">
  <div class="mx-auto max-w-7xl">
    <div class="grain relative overflow-hidden rounded-[2.6rem] border border-white/70 bg-charcoal px-6 py-10 text-cream shadow-[0_30px_90px_rgba(31,37,34,0.2)] sm:px-8 lg:px-12 lg:py-14">
      <div class="absolute inset-y-0 right-0 w-1/2 bg-[radial-gradient(circle_at_center,rgba(212,175,87,0.25),transparent_60%)]"></div>

      <div class="relative z-10 grid gap-8 lg:grid-cols-[1fr_0.9fr] lg:items-end">
        <div data-reveal>
          <p class="eyebrow text-cream/60">{t.sections.newsletter.eyebrow}</p>
          <h2 class="section-title mt-4 max-w-3xl text-4xl text-cream sm:text-5xl lg:text-6xl">
            {t.sections.newsletter.title}
          </h2>
          <p class="mt-5 max-w-2xl text-base leading-8 text-cream/72">
            {t.sections.newsletter.subtitle}
          </p>
        </div>

        <div class="rounded-[2rem] border border-white/12 bg-white/6 p-5 backdrop-blur-sm" data-reveal>
          <label class="text-sm uppercase tracking-[0.22em] text-cream/56" for="email">
            {t.sections.newsletter.emailLabel}
          </label>
          <input
            id="email"
            type="email"
            placeholder="bonjour@klarite.com"
            class="mt-3 w-full rounded-[1.4rem] border border-white/12 bg-white/8 px-5 py-4 text-base text-cream outline-none placeholder:text-cream/34"
          />
          <div class="mt-4 flex flex-col gap-3 sm:flex-row">
            <LinkButton href="mailto:bonjour@klarite.com" class="w-full justify-center">{t.sections.newsletter.button}</LinkButton>
            <LinkButton href="#boutique" variant="ghost" class="w-full justify-center border-white/18 bg-white/8 text-cream hover:bg-white/12 hover:text-cream">
              {t.sections.newsletter.secondaryButton}
            </LinkButton>
          </div>
          <p class="mt-4 text-sm leading-6 text-cream/56">
            {t.sections.newsletter.disclaimer}
          </p>
        </div>
      </div>
    </div>
  </div>
</section>
