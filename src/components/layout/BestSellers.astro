---
import ProductCard from "@/components/product/ProductCard.astro";
import SectionHeading from "@/components/ui/SectionHeading.astro";
import { getTranslations } from "@/i18n";
import type { Locale } from "@/i18n/config";

interface Props {
  products: any[];
  orderBtnLabel?: string;
  eyebrow?: string;
  title?: string;
  subtitle?: string;
  dragHint?: string;
}

const { products, orderBtnLabel = "Order Now", eyebrow, title, subtitle, dragHint } = Astro.props;
const locale = (Astro.currentLocale ?? "fr") as Locale;
const t = getTranslations(locale);
---

<section id="boutique" class="section-band section-band--warm py-20 sm:py-28">
  <div class="mx-auto max-w-[90rem] px-4 sm:px-6 lg:px-10">
    <SectionHeading
      eyebrow={eyebrow || t.sections.bestSellers.eyebrow}
      title={title || t.sections.bestSellers.title}
      copy={subtitle || t.sections.bestSellers.subtitle}
    />
  </div>

  <!-- Scroll container: full bleed so cards reach the edge on mobile -->
  <div
    class="mt-12 overflow-x-auto pb-6 [scrollbar-width:none] [-webkit-overflow-scrolling:touch] cursor-grab active:cursor-grabbing select-none"
    data-drag-scroll
  >
    <div class="flex snap-x snap-mandatory gap-5 px-4 sm:px-6 lg:px-10" style="width: max-content;">
      {products.map((product) => <ProductCard product={product} orderBtnLabel={orderBtnLabel} />)}
      <!-- Trailing spacer so last card isn't flush against edge -->
      <div class="w-4 shrink-0 lg:w-8" aria-hidden="true"></div>
    </div>
  </div>

  <!-- Drag hint visible on desktop, swipe hint on mobile -->
  <div class="mt-5 flex items-center justify-center gap-3 px-4">
    <div class="h-px w-8 bg-charcoal/15"></div>
    <p class="text-[0.6rem] uppercase tracking-[0.32em] text-charcoal/30">
      <span class="hidden md:inline">{dragHint || "← Glisser pour explorer →"}</span>
      <span class="md:hidden">← Swiper →</span>
    </p>
    <div class="h-px w-8 bg-charcoal/15"></div>
  </div>
</section>
