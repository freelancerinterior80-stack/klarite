---
import type { Product } from "@/data/products";
import LinkButton from "@/components/ui/LinkButton.astro";

interface Props {
  product: Product;
}

const { product } = Astro.props;
---

<article class="product-tilt ambient-card gold-shine flex min-w-[19rem] max-w-[22rem] snap-start flex-col rounded-[2rem] border border-white/70 p-5 shadow-[0_24px_60px_rgba(31,37,34,0.08)]">
  <div class:list={["asset-well h-64 rounded-[1.6rem] bg-gradient-to-br", product.accent]}>
    <div class="relative z-10 flex h-full flex-col justify-between p-5">
      <span class="eyebrow">{product.category}</span>
      <div>
        <p class="font-display text-3xl text-charcoal">{product.name}</p>
        <p class="mt-2 text-sm leading-6 text-charcoal/66">{product.shortDesc}</p>
      </div>
    </div>
  </div>

  <div class="mt-5 flex flex-1 flex-col">
    <p class="eyebrow">{product.originalName}</p>
    <p class="mt-3 text-sm leading-7 text-charcoal/72">{product.description}</p>
    <ul class="mt-5 flex flex-wrap gap-2">
      {product.notes.map((note) => <li class="rounded-full border border-charcoal/10 bg-white/55 px-3 py-1 text-xs uppercase tracking-[0.14em] text-charcoal/62">{note}</li>)}
    </ul>
    <p class="mt-5 text-sm leading-7 text-charcoal/66">{product.ritual}</p>
    <LinkButton href="#newsletter" variant="ghost" class="mt-6 w-full">Join Waitlist</LinkButton>
  </div>
</article>
