---
import { urlFor } from "@/sanity/image";

interface Props {
  product: any;
  orderBtnLabel?: string;
}

const { product, orderBtnLabel = "Order Now" } = Astro.props;

const imgSrc = product.image?.asset
  ? urlFor(product.image).width(640).format("webp").url()
  : "";

const galleryUrls: string[] = [
  ...(imgSrc ? [imgSrc] : []),
  ...(product.images ?? [])
    .filter((img: any) => img?.asset)
    .map((img: any) => urlFor(img).width(640).format("webp").url()),
];
---

<article class="group flex min-w-[17rem] max-w-[19rem] snap-start flex-col overflow-hidden rounded-[1.8rem] border border-white/80 bg-white shadow-[0_20px_56px_rgba(28,28,28,0.07)] transition-all duration-500 hover:-translate-y-1.5 hover:shadow-[0_32px_80px_rgba(28,28,28,0.12)]">

  <!-- ── Image zone ────────────────────────────────────────── -->
  <div
    class:list={[
      "relative overflow-hidden shrink-0",
      imgSrc ? "bg-[#f5f2ed]" : `bg-gradient-to-br ${product.accent ?? "from-stone-100 to-stone-200"}`,
    ]}
    style="height: 18rem;"
    data-images={galleryUrls.length > 1 ? JSON.stringify(galleryUrls) : undefined}
  >
    {imgSrc && (
      <img
        src={imgSrc}
        alt={product.image?.alt ?? product.name}
        class="gallery-img h-full w-full object-cover transition-transform duration-700 ease-[var(--ease-premium)] group-hover:scale-[1.06]"
        loading="lazy"
        decoding="async"
      />
    )}

    <!-- Bottom fade: image blends into card body -->
    <div class="absolute inset-x-0 bottom-0 h-16 bg-gradient-to-t from-white/60 to-transparent pointer-events-none"></div>

    <!-- Top-left: category pill -->
    <span class="absolute left-3 top-3 rounded-full border border-white/60 bg-white/85 px-3 py-1 text-[0.58rem] font-medium uppercase tracking-[0.2em] text-charcoal/65 backdrop-blur-sm shadow-sm">
      {product.category}
    </span>

    <!-- Top-right: price pill -->
    {product.price && (
      <span class="absolute right-3 top-3 rounded-full bg-charcoal/90 px-3 py-1.5 font-display text-[0.78rem] leading-none text-cream shadow-md backdrop-blur-sm">
        {product.price}
      </span>
    )}
  </div>

  <!-- ── Content ───────────────────────────────────────────── -->
  <div class="flex flex-1 flex-col px-5 pb-5 pt-4">

    <!-- Name -->
    <h3 class="font-display text-[1.65rem] leading-[1.1] tracking-[-0.02em] text-charcoal">
      {product.name}
    </h3>

    <!-- Short description -->
    <p class="mt-2.5 flex-1 text-[0.85rem] leading-[1.65] text-stone/75 line-clamp-2">
      {product.shortDesc}
    </p>

    <!-- CTA -->
    <div class="mt-4 border-t border-charcoal/[0.07] pt-4">
      <button
        class="enquire-btn cta-primary w-full"
        data-product-name={product.name ?? ""}
        data-product-slug={product.slug?.current ?? product.slug ?? ""}
        type="button"
      >
        {orderBtnLabel}
      </button>
    </div>
  </div>
</article>
