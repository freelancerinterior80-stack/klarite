---
import { urlFor } from "@/sanity/image";
import { getTranslations } from "@/i18n";
import type { Locale } from "@/i18n/config";

interface Props {
  product: any;
}

const { product } = Astro.props;
const locale = (Astro.currentLocale ?? "fr") as Locale;
const t = getTranslations(locale);

const waNumber = (import.meta.env.PUBLIC_WHATSAPP_NUMBER ?? "").replace(/\D/g, "");

const imgSrc = product.image?.asset
  ? urlFor(product.image).width(640).format("webp").url()
  : "";

const galleryUrls: string[] = [
  ...(imgSrc ? [imgSrc] : []),
  ...(product.images ?? [])
    .filter((img: any) => img?.asset)
    .map((img: any) => urlFor(img).width(640).format("webp").url()),
];

const waMsg = waNumber
  ? encodeURIComponent(`${t.whatsapp.prefix} ${product.name} — ${product.price}`)
  : null;
const waLink = waMsg ? `https://wa.me/${waNumber}?text=${waMsg}` : null;
---

<article class="group flex min-w-[17rem] max-w-[19rem] snap-start flex-col overflow-hidden rounded-[1.8rem] border border-white/80 bg-white shadow-[0_20px_56px_rgba(28,28,28,0.07)] transition-all duration-500 hover:-translate-y-1.5 hover:shadow-[0_32px_80px_rgba(28,28,28,0.12)]">

  <!-- ── Image zone ────────────────────────────────────────── -->
  <div
    class:list={[
      "relative overflow-hidden shrink-0",
      imgSrc ? "bg-[#f5f2ed]" : `bg-gradient-to-br ${product.accent ?? "from-stone-100 to-stone-200"}`,
    ]}
    style="height: 18rem;"
    data-images={galleryUrls.length > 1 ? JSON.stringify(galleryUrls) : undefined}
  >
    {imgSrc && (
      <img
        src={imgSrc}
        alt={product.image?.alt ?? product.name}
        class="gallery-img h-full w-full object-cover transition-transform duration-700 ease-[var(--ease-premium)] group-hover:scale-[1.06]"
        loading="lazy"
        decoding="async"
      />
    )}

    <!-- Bottom fade: image blends into card body -->
    <div class="absolute inset-x-0 bottom-0 h-16 bg-gradient-to-t from-white/60 to-transparent pointer-events-none"></div>

    <!-- Top-left: category pill -->
    <span class="absolute left-3 top-3 rounded-full border border-white/60 bg-white/85 px-3 py-1 text-[0.58rem] font-medium uppercase tracking-[0.2em] text-charcoal/65 backdrop-blur-sm shadow-sm">
      {product.category}
    </span>

    <!-- Top-right: price pill -->
    {product.price && (
      <span class="absolute right-3 top-3 rounded-full bg-charcoal/90 px-3 py-1.5 font-display text-[0.78rem] leading-none text-cream shadow-md backdrop-blur-sm">
        {product.price}
      </span>
    )}
  </div>

  <!-- ── Content ───────────────────────────────────────────── -->
  <div class="flex flex-1 flex-col px-5 pb-5 pt-4">

    <!-- Name -->
    <h3 class="font-display text-[1.65rem] leading-[1.1] tracking-[-0.02em] text-charcoal">
      {product.name}
    </h3>

    <!-- Short description -->
    <p class="mt-2.5 flex-1 text-[0.85rem] leading-[1.65] text-stone/75 line-clamp-2">
      {product.shortDesc}
    </p>

    <!-- CTA -->
    <div class="mt-4 border-t border-charcoal/[0.07] pt-4">
      {waLink ? (
        <a
          href={waLink}
          target="_blank"
          rel="noopener noreferrer"
          class="wa-btn w-full"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          {t.product.orderViaWhatsapp}
        </a>
      ) : (
        <a href="#newsletter" class="cta-secondary w-full text-center text-[0.65rem] leading-none">
          {t.product.joinWaitlist}
        </a>
      )}
    </div>
  </div>
</article>
