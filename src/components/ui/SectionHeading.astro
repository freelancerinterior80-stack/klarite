---
interface Props {
  eyebrow: string;
  title: string;
  copy: string;
  align?: "left" | "center";
}

const { eyebrow, title, copy, align = "left" } = Astro.props;
const centered = align === "center";
---

<div class:list={["max-w-3xl", centered && "mx-auto text-center"]} data-reveal>
  <p class="eyebrow mb-4">{eyebrow}</p>
  <h2 class="section-title text-balance text-4xl text-charcoal sm:text-5xl lg:text-6xl">
    {title}
  </h2>
  <p class:list={["mt-5 max-w-2xl text-base leading-7 text-charcoal/72 sm:text-lg", centered && "mx-auto"]}>
    {copy}
  </p>
</div>
