---
export const prerender = false;
import AdminLayout from "@/layouts/AdminLayout.astro";
import { writeClient } from "@/sanity/write-client";

const { id } = Astro.params as { id: string };

// Handle mark-unread action
if (Astro.request.method === "POST") {
  const form = await Astro.request.formData();
  if (form.get("_action") === "mark-unread") {
    await writeClient.patch(id).set({ isRead: false }).commit();
    return Astro.redirect(`/admin/inquiries/${id}`);
  }
}

const inq = await writeClient.fetch<{
  _id: string;
  _createdAt: string;
  productName: string;
  productSlug: string;
  customerName: string;
  phone: string;
  email: string;
  message: string;
  locale: string;
  isRead: boolean;
} | null>(
  `*[_id == $id][0]{ _id, _createdAt, productName, productSlug, customerName, phone, email, message, locale, isRead }`,
  { id }
);

if (!inq) return Astro.redirect("/admin/inquiries");

// Auto-mark as read
if (!inq.isRead) {
  await writeClient.patch(id).set({ isRead: true }).commit();
  inq.isRead = true;
}

function formatDateTime(iso: string) {
  return new Date(iso).toLocaleString("en-GB", {
    weekday: "long", day: "numeric", month: "long", year: "numeric",
    hour: "2-digit", minute: "2-digit",
  });
}
---

<AdminLayout title="Inquiry">
  <div class="mb-6 flex items-center justify-between">
    <a href="/admin/inquiries" class="text-xs text-charcoal/45 transition hover:text-charcoal">← Back to Inquiries</a>
    <form method="POST">
      <input type="hidden" name="_action" value="mark-unread" />
      <button type="submit" class="rounded-xl border border-charcoal/12 bg-white/70 px-4 py-2 text-xs font-medium text-charcoal transition hover:bg-charcoal/5">
        Mark as unread
      </button>
    </form>
  </div>

  <div class="max-w-2xl space-y-5">
    <!-- Product + date header -->
    <div class="rounded-[1.5rem] bg-charcoal px-8 py-6 text-cream shadow-lg">
      <div class="flex items-start justify-between gap-4">
        <div>
          <p class="eyebrow text-cream/50 mb-1">Enquiry about</p>
          <h2 class="font-display text-2xl leading-tight">{inq.productName || "General Enquiry"}</h2>
        </div>
        {inq.locale && (
          <span class="shrink-0 rounded-full border border-white/20 px-3 py-1 text-[0.68rem] font-medium uppercase tracking-wider text-cream/60">
            {inq.locale.toUpperCase()}
          </span>
        )}
      </div>
      <p class="mt-3 text-xs text-cream/45">{formatDateTime(inq._createdAt)}</p>
    </div>

    <!-- Customer info -->
    <div class="rounded-[1.5rem] border border-charcoal/10 bg-white/70 p-7 shadow-sm">
      <h3 class="mb-5 text-xs font-medium uppercase tracking-wider text-charcoal/50">Customer Details</h3>
      <div class="space-y-4">
        <div class="flex items-center gap-4">
          <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-charcoal/8 text-sm font-medium text-charcoal/60">
            {(inq.customerName || "?")[0].toUpperCase()}
          </div>
          <div>
            <p class="text-base font-semibold text-charcoal">{inq.customerName || "Anonymous"}</p>
          </div>
        </div>

        <div class="grid gap-3 sm:grid-cols-2">
          {inq.phone && (
            <div class="rounded-xl border border-charcoal/8 bg-charcoal/[0.02] px-4 py-3">
              <p class="mb-0.5 text-[0.65rem] font-medium uppercase tracking-wider text-charcoal/40">Phone</p>
              <a href={`tel:${inq.phone}`} class="text-sm font-medium text-charcoal transition hover:text-gold">{inq.phone}</a>
            </div>
          )}
          {inq.email && (
            <div class="rounded-xl border border-charcoal/8 bg-charcoal/[0.02] px-4 py-3">
              <p class="mb-0.5 text-[0.65rem] font-medium uppercase tracking-wider text-charcoal/40">Email</p>
              <a href={`mailto:${inq.email}`} class="text-sm font-medium text-charcoal transition hover:text-gold">{inq.email}</a>
            </div>
          )}
        </div>
      </div>
    </div>

    <!-- Message -->
    {inq.message && (
      <div class="rounded-[1.5rem] border border-charcoal/10 bg-white/70 p-7 shadow-sm">
        <h3 class="mb-4 text-xs font-medium uppercase tracking-wider text-charcoal/50">Message</h3>
        <blockquote class="border-l-[3px] border-gold/50 pl-5 text-sm leading-relaxed text-charcoal/80">
          {inq.message}
        </blockquote>
      </div>
    )}
  </div>
</AdminLayout>
