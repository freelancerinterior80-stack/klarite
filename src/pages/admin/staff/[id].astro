---
export const prerender = false;
import AdminLayout from "@/layouts/AdminLayout.astro";
import { writeClient } from "@/sanity/write-client";
import { hashPassword } from "@/lib/admin-auth";

const { id } = Astro.params as { id: string };
let successMsg = "";
let error = "";

if (Astro.request.method === "POST") {
  const form = await Astro.request.formData();
  const action = form.get("_action") as string;

  if (action === "toggle-active") {
    const current = await writeClient.fetch<{ isActive: boolean }>(`*[_id == $id][0]{ isActive }`, { id });
    await writeClient.patch(id).set({ isActive: !current?.isActive }).commit();
    successMsg = "Account status updated.";
  } else if (action === "reset-password") {
    const newPass = (form.get("newPassword") as string ?? "").trim();
    if (!newPass || newPass.length < 8) {
      error = "Password must be at least 8 characters.";
    } else {
      const passwordHash = await hashPassword(newPass);
      await writeClient.patch(id).set({ passwordHash }).commit();
      successMsg = "Password reset successfully.";
    }
  }
}

const doc = await writeClient.fetch<{
  _id: string; displayName: string; username: string; isActive: boolean;
} | null>(`*[_id == $id][0]{ _id, displayName, username, isActive }`, { id });

if (!doc) return Astro.redirect("/admin/staff");
---

<AdminLayout title={`Staff: ${doc.displayName}`}>
  <div class="mb-6">
    <a href="/admin/staff" class="text-xs text-charcoal/45 transition hover:text-charcoal">← Back to Staff</a>
  </div>

  {successMsg && (
    <div class="mb-6 rounded-xl border border-emerald-200 bg-emerald-50 px-5 py-3 text-sm text-emerald-700">{successMsg}</div>
  )}
  {error && (
    <div class="mb-6 rounded-xl border border-red-200 bg-red-50 px-5 py-3 text-sm text-red-700">{error}</div>
  )}

  <div class="max-w-lg space-y-5">
    <!-- Info card (read-only) -->
    <div class="rounded-[1.5rem] border border-charcoal/10 bg-white/70 p-7 shadow-sm">
      <h2 class="mb-4 text-xs font-medium uppercase tracking-wider text-charcoal/50">Account Info</h2>
      <p class="text-lg font-semibold text-charcoal">{doc.displayName}</p>
      <p class="mt-0.5 text-sm text-charcoal/50">@{doc.username}</p>
      <div class="mt-4 flex items-center gap-3">
        <span class:list={[
          "rounded-full px-3 py-1 text-[0.68rem] font-medium uppercase tracking-wider border",
          doc.isActive
            ? "bg-emerald-100 text-emerald-700 border-emerald-200"
            : "bg-charcoal/8 text-charcoal/45 border-charcoal/10",
        ]}>
          {doc.isActive ? "Active" : "Inactive"}
        </span>
      </div>
    </div>

    <!-- Toggle active/inactive -->
    <div class="rounded-[1.5rem] border border-charcoal/10 bg-white/70 p-7 shadow-sm">
      <h2 class="mb-1 text-xs font-medium uppercase tracking-wider text-charcoal/50">Account Status</h2>
      <p class="mb-4 text-xs text-charcoal/40">
        {doc.isActive
          ? "Staff can currently log in. Deactivate to block access immediately."
          : "Staff cannot log in. Activate to restore access."}
      </p>
      <form method="POST">
        <input type="hidden" name="_action" value="toggle-active" />
        <button
          type="submit"
          class:list={[
            "rounded-xl px-5 py-2.5 text-sm font-medium transition",
            doc.isActive
              ? "bg-red-50 border border-red-200 text-red-700 hover:bg-red-100"
              : "bg-emerald-50 border border-emerald-200 text-emerald-700 hover:bg-emerald-100",
          ]}
        >
          {doc.isActive ? "Deactivate Account" : "Activate Account"}
        </button>
      </form>
    </div>

    <!-- Reset password -->
    <div class="rounded-[1.5rem] border border-charcoal/10 bg-white/70 p-7 shadow-sm">
      <h2 class="mb-1 text-xs font-medium uppercase tracking-wider text-charcoal/50">Reset Password</h2>
      <p class="mb-4 text-xs text-charcoal/40">Set a new password for this staff member.</p>
      <form method="POST" class="flex gap-3">
        <input type="hidden" name="_action" value="reset-password" />
        <input
          type="password"
          name="newPassword"
          required
          minlength="8"
          placeholder="New password (min 8 chars)"
          class="admin-input flex-1"
          autocomplete="new-password"
        />
        <button type="submit" class="shrink-0 rounded-xl bg-charcoal px-5 py-2.5 text-sm font-medium text-cream transition hover:bg-charcoal/80">
          Reset
        </button>
      </form>
    </div>
  </div>
</AdminLayout>
