---
export const prerender = false;
import AdminLayout from "@/layouts/AdminLayout.astro";
import { writeClient } from "@/sanity/write-client";

const loc = (arr: any[] | null | undefined, key: string) =>
  arr?.find((i: any) => i._key === key)?.value ?? "";

let error = "";
let successMsg = "";

const DEFAULTS = {
  eyebrow: "Toucher Doux",
  headline_fr: "Quiet luxury for skin that looks luminous and composed.",
  headline_en: "Quiet luxury for skin that looks luminous and composed.",
  headline_ar: "فخامة هادئة لبشرة تبدو مضيئة ومتناسقة.",
  body_fr: "KLARITE distille le rituel de la beauté française en formules calmes et performantes.",
  body_en: "KLARITE distills the ritual of French beauty into calm, high-performance formulas with clinical clarity and a soft editorial finish.",
  body_ar: "تُقطّر كلاريتي طقوس الجمال الفرنسي في تركيبات هادئة عالية الأداء.",
  cta1_fr: "Découvrir la collection", cta1_en: "Shop Collection", cta1_ar: "تسوّقي المجموعة",
  cta2_fr: "Diagnostic Peau", cta2_en: "Skin Quiz", cta2_ar: "اختبار البشرة",
  trust1_fr: "Retenue parisienne", trust1_en: "Parisian restraint", trust1_ar: "رقي باريسي",
  trust2_fr: "Douceur visible", trust2_en: "Visible softness", trust2_ar: "نعومة مرئية",
  trust3_fr: "Rituels quotidiens", trust3_en: "Refined daily rituals", trust3_ar: "طقوس يومية راقية",
  formulaEyebrow_fr: "Formule Phare", formulaEyebrow_en: "Hero Formula", formulaEyebrow_ar: "الفورمولا المميزة",
  formulaText_fr: "Hydratation coussin avec un éclat satiné.", formulaText_en: "Cushion-soft hydration with a satin glow.", formulaText_ar: "ترطيب بوسائدي مع بريق حريري.",
  badgeLabel_fr: "Soin Signature", badgeLabel_en: "Signature Care", badgeLabel_ar: "عناية مميزة",
  badgeTitle_fr: "Crème Visage", badgeTitle_en: "Face Cream", badgeTitle_ar: "كريم الوجه",
};

if (Astro.request.method === "POST") {
  const form = await Astro.request.formData();
  const action = (form.get("_action") as string) ?? "save";

  try {
    await writeClient.createIfNotExists({ _id: "heroSettings", _type: "heroSettings" });

    if (action === "set-media-type") {
      const mediaType = (form.get("mediaType") as string) ?? "image";
      await writeClient.patch("heroSettings").set({ mediaType }).commit();
      successMsg = "Media type updated.";

    } else if (action === "upload-hero-image") {
      const file = form.get("heroImage") as File | null;
      if (file && file.size > 0) {
        const buffer = Buffer.from(await file.arrayBuffer());
        const asset = await writeClient.assets.upload("image", buffer, {
          filename: file.name,
          contentType: file.type,
        });
        await writeClient.patch("heroSettings").set({
          heroImage: { _type: "image", asset: { _type: "reference", _ref: asset._id } },
          mediaType: "image",
        }).commit();
        successMsg = "Hero image uploaded and set as active.";
      } else {
        error = "No image file selected.";
      }

    } else if (action === "upload-hero-video") {
      const file = form.get("heroVideoFile") as File | null;
      if (file && file.size > 0) {
        const buffer = Buffer.from(await file.arrayBuffer());
        const asset = await writeClient.assets.upload("file", buffer, {
          filename: file.name,
          contentType: file.type,
        });
        await writeClient.patch("heroSettings").set({
          heroVideoFile: { _type: "file", asset: { _type: "reference", _ref: asset._id } },
          mediaType: "video",
        }).commit();
        successMsg = "Hero video uploaded and set as active.";
      } else {
        error = "No video file selected.";
      }

    } else if (action === "save-video-url") {
      const url = (form.get("heroVideoUrl") as string) ?? "";
      await writeClient.patch("heroSettings").set({
        heroVideoUrl: url,
        mediaType: "video",
      }).commit();
      successMsg = "Video URL saved and set as active.";

    } else if (action === "upload-badge") {
      const file = form.get("badgeImage") as File | null;
      if (file && file.size > 0) {
        const buffer = Buffer.from(await file.arrayBuffer());
        const asset = await writeClient.assets.upload("image", buffer, {
          filename: file.name,
          contentType: file.type,
        });
        await writeClient.patch("heroSettings").set({
          badgeImage: { _type: "image", asset: { _type: "reference", _ref: asset._id } },
        }).commit();
        successMsg = "Badge image updated.";
      } else {
        error = "No badge image selected.";
      }

    } else if (action === "save-typography") {
      await writeClient.patch("heroSettings").set({
        headlineFontFamily: (form.get("headlineFontFamily") as string) ?? "",
        headlineFontSize:   (form.get("headlineFontSize")   as string) ?? "",
        headlineFontWeight: (form.get("headlineFontWeight") as string) ?? "",
        headlineAlignment:  (form.get("headlineAlignment")  as string) ?? "left",
      }).commit();
      successMsg = "Typography saved.";

    } else if (action === "save-ticker") {
      const raw = (form.get("tickerPhrases") as string) ?? "";
      const phrases = raw.split("\n").map((s: string) => s.trim()).filter(Boolean);
      await writeClient.patch("heroSettings").set({ tickerPhrases: phrases }).commit();
      successMsg = "Ticker phrases saved.";

    } else {
      const g = (name: string) => (form.get(name) as string) ?? "";
      await writeClient.patch("heroSettings").set({
        eyebrow: g("eyebrow"),
        'headline[_key=="fr"].value': g("headline_fr"),
        'headline[_key=="en"].value': g("headline_en"),
        'headline[_key=="ar"].value': g("headline_ar"),
        'body[_key=="fr"].value': g("body_fr"),
        'body[_key=="en"].value': g("body_en"),
        'body[_key=="ar"].value': g("body_ar"),
        'cta1Label[_key=="fr"].value': g("cta1_fr"),
        'cta1Label[_key=="en"].value': g("cta1_en"),
        'cta1Label[_key=="ar"].value': g("cta1_ar"),
        'cta2Label[_key=="fr"].value': g("cta2_fr"),
        'cta2Label[_key=="en"].value': g("cta2_en"),
        'cta2Label[_key=="ar"].value': g("cta2_ar"),
        'trust1[_key=="fr"].value': g("trust1_fr"),
        'trust1[_key=="en"].value': g("trust1_en"),
        'trust1[_key=="ar"].value': g("trust1_ar"),
        'trust2[_key=="fr"].value': g("trust2_fr"),
        'trust2[_key=="en"].value': g("trust2_en"),
        'trust2[_key=="ar"].value': g("trust2_ar"),
        'trust3[_key=="fr"].value': g("trust3_fr"),
        'trust3[_key=="en"].value': g("trust3_en"),
        'trust3[_key=="ar"].value': g("trust3_ar"),
        'formulaEyebrow[_key=="fr"].value': g("formulaEyebrow_fr"),
        'formulaEyebrow[_key=="en"].value': g("formulaEyebrow_en"),
        'formulaEyebrow[_key=="ar"].value': g("formulaEyebrow_ar"),
        'formulaText[_key=="fr"].value': g("formulaText_fr"),
        'formulaText[_key=="en"].value': g("formulaText_en"),
        'formulaText[_key=="ar"].value': g("formulaText_ar"),
        'badgeLabel[_key=="fr"].value': g("badgeLabel_fr"),
        'badgeLabel[_key=="en"].value': g("badgeLabel_en"),
        'badgeLabel[_key=="ar"].value': g("badgeLabel_ar"),
        'badgeTitle[_key=="fr"].value': g("badgeTitle_fr"),
        'badgeTitle[_key=="en"].value': g("badgeTitle_en"),
        'badgeTitle[_key=="ar"].value': g("badgeTitle_ar"),
      }).commit();
      successMsg = "Hero text saved.";
    }
  } catch (e) {
    error = "Save failed. Please try again.";
  }
}

// Bootstrap empty doc on first visit
const _existing = await writeClient.fetch(`*[_id == "heroSettings"][0]`);
if (!_existing) {
  const emptyLoc = (fields: string[]) =>
    fields.reduce((acc: any, f: string) => ({
      ...acc,
      [f]: [{ _key: "fr", value: "" }, { _key: "en", value: "" }, { _key: "ar", value: "" }],
    }), {});

  await writeClient.createIfNotExists({
    _id: "heroSettings",
    _type: "heroSettings",
    ...emptyLoc(["headline","body","cta1Label","cta2Label","trust1","trust2","trust3","formulaEyebrow","formulaText","badgeLabel","badgeTitle"]),
  });
}

const doc = await writeClient.fetch(`*[_id == "heroSettings"][0]{
  ...,
  "heroImageUrl": heroImage.asset->url,
  "badgeImageUrl": badgeImage.asset->url,
  "heroVideoFileUrl": heroVideoFile.asset->url,
  tickerPhrases,
  headlineFontFamily,
  headlineFontSize,
  headlineFontWeight,
  headlineAlignment,
}`);

const v = (field: string, locale: string) => loc(doc?.[field], locale);
const val = (field: string, locale: string, fallback: string) =>
  v(field, locale) || (DEFAULTS as any)[`${field}_${locale}`] || fallback;

const currentMediaType: string = doc?.mediaType ?? "image";
---

<AdminLayout title="Hero Section">
  <div class="mb-8">
    <h1 class="font-display text-3xl text-charcoal">Hero Section</h1>
    <p class="mt-1 text-sm text-charcoal/55">Manage media, headline, body, buttons, trust points, and callout for the homepage hero.</p>
  </div>

  {error && <div class="mb-6 rounded-xl border border-red-200 bg-red-50 px-5 py-3 text-sm text-red-700">{error}</div>}
  {successMsg && <div class="mb-6 rounded-xl border border-green-200 bg-green-50 px-5 py-3 text-sm text-green-700">{successMsg}</div>}

  <!-- ── MEDIA ──────────────────────────────────────────────── -->
  <div class="rounded-[1.5rem] border border-charcoal/10 bg-white/70 p-7 shadow-[0_8px_30px_rgba(31,37,34,0.06)] mb-6">
    <h2 class="mb-1 text-xs font-medium uppercase tracking-wider text-charcoal/50">Hero Media</h2>
    <p class="mb-6 text-xs text-charcoal/40">Choose image or video, then upload or paste a link. Uploading automatically switches the active type.</p>

    <!-- Media type switcher -->
    <form method="POST" class="mb-7 flex flex-wrap items-center gap-4">
      <input type="hidden" name="_action" value="set-media-type" />
      <span class="text-sm font-medium text-charcoal">Active type:</span>
      <label class="flex cursor-pointer items-center gap-2">
        <input type="radio" name="mediaType" value="image" class="accent-gold" checked={currentMediaType === "image"} />
        <span class="text-sm text-charcoal">Image</span>
      </label>
      <label class="flex cursor-pointer items-center gap-2">
        <input type="radio" name="mediaType" value="video" class="accent-gold" checked={currentMediaType === "video"} />
        <span class="text-sm text-charcoal">Video</span>
      </label>
      <button type="submit" class="rounded-xl border border-charcoal/15 bg-charcoal/6 px-5 py-1.5 text-xs font-medium text-charcoal transition hover:bg-charcoal/10">
        Apply Type
      </button>
      <span class="text-xs text-charcoal/40">Currently: <strong class="capitalize text-charcoal">{currentMediaType}</strong></span>
    </form>

    <div class="grid gap-5 lg:grid-cols-2">

      <!-- Hero Image -->
      <div class="rounded-xl border border-charcoal/10 bg-[#f8f6f2] p-5">
        <div class="mb-3 flex items-center gap-2">
          <p class="text-xs font-medium uppercase tracking-wider text-charcoal/50">Hero Image</p>
          {currentMediaType === "image" && (
            <span class="rounded-full bg-green-100 px-2 py-0.5 text-[10px] font-medium uppercase tracking-wide text-green-700">Active</span>
          )}
        </div>
        {doc?.heroImageUrl ? (
          <div class="mb-4 overflow-hidden rounded-lg border border-charcoal/10">
            <img src={`${doc.heroImageUrl}?w=600&h=380&fit=crop&auto=format`} alt="Current hero image" class="h-44 w-full object-cover" />
          </div>
        ) : (
          <div class="mb-4 flex h-44 items-center justify-center rounded-lg border-2 border-dashed border-charcoal/12 text-xs text-charcoal/30">
            No image uploaded yet
          </div>
        )}
        <form method="POST" enctype="multipart/form-data">
          <input type="hidden" name="_action" value="upload-hero-image" />
          <div class="flex items-center gap-2">
            <input
              type="file"
              name="heroImage"
              accept="image/jpeg,image/png,image/webp"
              class="flex-1 rounded-lg border border-charcoal/15 bg-white px-3 py-2 text-xs text-charcoal file:mr-3 file:rounded-md file:border-0 file:bg-charcoal file:px-3 file:py-1.5 file:text-xs file:font-medium file:text-cream hover:file:bg-charcoal/80"
            />
            <button type="submit" class="shrink-0 rounded-xl bg-charcoal px-4 py-2 text-xs font-medium text-cream transition hover:bg-charcoal/80">
              Upload
            </button>
          </div>
          <p class="mt-2 text-[10px] text-charcoal/35">Recommended: 1800 × 1200 px, JPG or WebP. Uploading switches the hero to Image mode.</p>
        </form>
      </div>

      <!-- Hero Video -->
      <div class="rounded-xl border border-charcoal/10 bg-[#f8f6f2] p-5">
        <div class="mb-3 flex items-center gap-2">
          <p class="text-xs font-medium uppercase tracking-wider text-charcoal/50">Hero Video</p>
          {currentMediaType === "video" && (
            <span class="rounded-full bg-green-100 px-2 py-0.5 text-[10px] font-medium uppercase tracking-wide text-green-700">Active</span>
          )}
        </div>

        {doc?.heroVideoFileUrl && (
          <div class="mb-3 flex items-center gap-3 rounded-lg border border-charcoal/10 bg-white px-4 py-3">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 text-charcoal/40"><polygon points="5 3 19 12 5 21 5 3"/></svg>
            <span class="truncate text-xs text-charcoal/60">Uploaded video file</span>
          </div>
        )}
        {doc?.heroVideoUrl && (
          <div class="mb-3 flex items-center gap-3 rounded-lg border border-charcoal/10 bg-white px-4 py-3">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 text-charcoal/40"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
            <span class="truncate text-xs text-charcoal/60">{doc.heroVideoUrl}</span>
          </div>
        )}
        {!doc?.heroVideoFileUrl && !doc?.heroVideoUrl && (
          <div class="mb-3 flex h-16 items-center justify-center rounded-lg border-2 border-dashed border-charcoal/12 text-xs text-charcoal/30">
            No video yet
          </div>
        )}

        <!-- Upload file -->
        <form method="POST" enctype="multipart/form-data" class="mb-4">
          <input type="hidden" name="_action" value="upload-hero-video" />
          <p class="mb-2 text-[10px] font-medium uppercase tracking-wider text-charcoal/40">Upload file (MP4 / WebM)</p>
          <div class="flex items-center gap-2">
            <input
              type="file"
              name="heroVideoFile"
              accept="video/mp4,video/webm"
              class="flex-1 rounded-lg border border-charcoal/15 bg-white px-3 py-2 text-xs text-charcoal file:mr-3 file:rounded-md file:border-0 file:bg-charcoal file:px-3 file:py-1.5 file:text-xs file:font-medium file:text-cream hover:file:bg-charcoal/80"
            />
            <button type="submit" class="shrink-0 rounded-xl bg-charcoal px-4 py-2 text-xs font-medium text-cream transition hover:bg-charcoal/80">
              Upload
            </button>
          </div>
        </form>

        <!-- Or paste URL -->
        <form method="POST">
          <input type="hidden" name="_action" value="save-video-url" />
          <p class="mb-2 text-[10px] font-medium uppercase tracking-wider text-charcoal/40">Or paste external URL (.mp4 / .webm)</p>
          <div class="flex items-center gap-2">
            <input
              name="heroVideoUrl"
              type="url"
              placeholder="https://example.com/video.mp4"
              value={doc?.heroVideoUrl ?? ""}
              class="admin-input flex-1"
            />
            <button type="submit" class="shrink-0 rounded-xl bg-charcoal px-4 py-2 text-xs font-medium text-cream transition hover:bg-charcoal/80">
              Save URL
            </button>
          </div>
          <p class="mt-2 text-[10px] text-charcoal/35">Uploading a file takes priority over this URL. Both switch the hero to Video mode.</p>
        </form>
      </div>
    </div>

    <!-- Badge Image -->
    <div class="mt-5 rounded-xl border border-charcoal/10 bg-[#f8f6f2] p-5">
      <p class="mb-1 text-xs font-medium uppercase tracking-wider text-charcoal/50">Product Badge Image</p>
      <p class="mb-4 text-xs text-charcoal/40">The small photo shown in the floating product card on the hero.</p>
      <div class="flex flex-wrap items-start gap-5">
        {doc?.badgeImageUrl ? (
          <div class="h-24 w-24 shrink-0 overflow-hidden rounded-xl border border-charcoal/10">
            <img src={`${doc.badgeImageUrl}?w=200&h=200&fit=crop&auto=format`} alt="Badge product" class="h-full w-full object-cover" />
          </div>
        ) : (
          <div class="flex h-24 w-24 shrink-0 items-center justify-center rounded-xl border-2 border-dashed border-charcoal/12 text-xs text-charcoal/30">
            None
          </div>
        )}
        <form method="POST" enctype="multipart/form-data" class="flex-1 min-w-[200px]">
          <input type="hidden" name="_action" value="upload-badge" />
          <div class="flex items-center gap-2">
            <input
              type="file"
              name="badgeImage"
              accept="image/jpeg,image/png,image/webp"
              class="flex-1 rounded-lg border border-charcoal/15 bg-white px-3 py-2 text-xs text-charcoal file:mr-3 file:rounded-md file:border-0 file:bg-charcoal file:px-3 file:py-1.5 file:text-xs file:font-medium file:text-cream hover:file:bg-charcoal/80"
            />
            <button type="submit" class="shrink-0 rounded-xl bg-charcoal px-4 py-2 text-xs font-medium text-cream transition hover:bg-charcoal/80">
              Upload
            </button>
          </div>
          <p class="mt-2 text-[10px] text-charcoal/35">Recommended: square image, 400 × 400 px minimum.</p>
        </form>
      </div>
    </div>
  </div>

  <!-- ── HEADLINE TYPOGRAPHY ──────────────────────────────────── -->
  <div class="rounded-[1.5rem] border border-charcoal/10 bg-white/70 p-7 shadow-[0_8px_30px_rgba(31,37,34,0.06)] mb-6">
    <h2 class="mb-1 text-xs font-medium uppercase tracking-wider text-charcoal/50">Headline Typography</h2>
    <p class="mb-6 text-xs text-charcoal/40">Controls the font family, size, and weight of the large hero headline. Uses fonts already installed on the visitor's device — no loading delay.</p>

    <form method="POST" class="space-y-6" id="typo-form">
      <input type="hidden" name="_action" value="save-typography" />

      <div class="grid gap-5 sm:grid-cols-4">

        <!-- Font family -->
        <div class="admin-field">
          <label>Font Family</label>
          <select name="headlineFontFamily" id="typo-font" class="admin-input">
            <optgroup label="— Web fonts (already loaded) —">
              <option value="'Playfair Display', Georgia, serif" selected={(!doc?.headlineFontFamily || doc.headlineFontFamily === "'Playfair Display', Georgia, serif") || undefined}>Playfair Display (current)</option>
              <option value="Inter, Arial, sans-serif" selected={doc?.headlineFontFamily === "Inter, Arial, sans-serif" || undefined}>Inter</option>
              <option value="Cairo, Arial, sans-serif" selected={doc?.headlineFontFamily === "Cairo, Arial, sans-serif" || undefined}>Cairo (Arabic)</option>
            </optgroup>
            <optgroup label="— System serif —">
              <option value="Georgia, serif" selected={doc?.headlineFontFamily === "Georgia, serif" || undefined}>Georgia</option>
              <option value="'Palatino Linotype', Palatino, serif" selected={doc?.headlineFontFamily === "'Palatino Linotype', Palatino, serif" || undefined}>Palatino</option>
              <option value="'Times New Roman', Times, serif" selected={doc?.headlineFontFamily === "'Times New Roman', Times, serif" || undefined}>Times New Roman</option>
              <option value="Garamond, serif" selected={doc?.headlineFontFamily === "Garamond, serif" || undefined}>Garamond</option>
              <option value="'Book Antiqua', Palatino, serif" selected={doc?.headlineFontFamily === "'Book Antiqua', Palatino, serif" || undefined}>Book Antiqua</option>
              <option value="Baskerville, serif" selected={doc?.headlineFontFamily === "Baskerville, serif" || undefined}>Baskerville</option>
            </optgroup>
            <optgroup label="— System sans-serif —">
              <option value="'Helvetica Neue', Helvetica, Arial, sans-serif" selected={doc?.headlineFontFamily === "'Helvetica Neue', Helvetica, Arial, sans-serif" || undefined}>Helvetica Neue</option>
              <option value="Arial, Helvetica, sans-serif" selected={doc?.headlineFontFamily === "Arial, Helvetica, sans-serif" || undefined}>Arial</option>
              <option value="Verdana, Geneva, sans-serif" selected={doc?.headlineFontFamily === "Verdana, Geneva, sans-serif" || undefined}>Verdana</option>
              <option value="'Trebuchet MS', Arial, sans-serif" selected={doc?.headlineFontFamily === "'Trebuchet MS', Arial, sans-serif" || undefined}>Trebuchet MS</option>
              <option value="'Gill Sans', Optima, sans-serif" selected={doc?.headlineFontFamily === "'Gill Sans', Optima, sans-serif" || undefined}>Gill Sans</option>
              <option value="Optima, 'Segoe UI', sans-serif" selected={doc?.headlineFontFamily === "Optima, 'Segoe UI', sans-serif" || undefined}>Optima</option>
              <option value="'Century Gothic', Futura, sans-serif" selected={doc?.headlineFontFamily === "'Century Gothic', Futura, sans-serif" || undefined}>Century Gothic</option>
              <option value="'Segoe UI', Arial, sans-serif" selected={doc?.headlineFontFamily === "'Segoe UI', Arial, sans-serif" || undefined}>Segoe UI</option>
              <option value="Tahoma, Geneva, sans-serif" selected={doc?.headlineFontFamily === "Tahoma, Geneva, sans-serif" || undefined}>Tahoma</option>
            </optgroup>
          </select>
        </div>

        <!-- Font size -->
        <div class="admin-field">
          <label>Font Size — <span id="typo-size-display">{doc?.headlineFontSize ?? "7.5"}rem</span></label>
          <input
            type="range"
            name="headlineFontSize"
            id="typo-size"
            min="2"
            max="10"
            step="0.1"
            value={doc?.headlineFontSize ?? "7.5"}
            class="mt-3 w-full accent-gold"
          />
          <div class="mt-1 flex justify-between text-[10px] text-charcoal/35">
            <span>2 rem (small)</span><span>10 rem (huge)</span>
          </div>
        </div>

        <!-- Font weight -->
        <div class="admin-field">
          <label>Font Weight</label>
          <select name="headlineFontWeight" id="typo-weight" class="admin-input">
            <option value="400" selected={(!doc?.headlineFontWeight || doc.headlineFontWeight === "400") || undefined}>400 — Regular</option>
            <option value="500" selected={doc?.headlineFontWeight === "500" || undefined}>500 — Medium</option>
            <option value="600" selected={doc?.headlineFontWeight === "600" || undefined}>600 — SemiBold</option>
            <option value="700" selected={doc?.headlineFontWeight === "700" || undefined}>700 — Bold</option>
            <option value="800" selected={doc?.headlineFontWeight === "800" || undefined}>800 — ExtraBold</option>
            <option value="900" selected={doc?.headlineFontWeight === "900" || undefined}>900 — Black</option>
          </select>
        </div>

        <!-- Alignment -->
        <div class="admin-field">
          <label>Alignment</label>
          <div class="mt-1 flex gap-1" id="align-group">
            {(["left","center","right"] as const).map((a) => {
              const isActive = (doc?.headlineAlignment ?? "left") === a;
              const icons = {
                left:   `<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="15" y2="12"/><line x1="3" y1="18" x2="18" y2="18"/></svg>`,
                center: `<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="6" y1="12" x2="18" y2="12"/><line x1="4" y1="18" x2="20" y2="18"/></svg>`,
                right:  `<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="9" y1="12" x2="21" y2="12"/><line x1="6" y1="18" x2="21" y2="18"/></svg>`,
              };
              return (
                <label class:list={["flex flex-1 cursor-pointer items-center justify-center rounded-lg border py-2 transition", isActive ? "border-charcoal bg-charcoal text-cream" : "border-charcoal/15 bg-white text-charcoal/60 hover:border-charcoal/30"]}>
                  <input type="radio" name="headlineAlignment" value={a} checked={isActive || undefined} class="sr-only" />
                  <span set:html={icons[a]} />
                </label>
              );
            })}
          </div>
        </div>
      </div>

      <!-- Live preview -->
      <div class="rounded-xl border border-charcoal/10 bg-[#f8f6f2] px-6 py-5 overflow-hidden">
        <p class="mb-3 text-[10px] uppercase tracking-widest text-charcoal/35">Live Preview</p>
        <p
          id="typo-preview"
          style={`font-family:${doc?.headlineFontFamily ?? "'Playfair Display', Georgia, serif"}; font-size: clamp(1.6rem, 4vw, ${doc?.headlineFontSize ?? "7.5"}rem); font-weight:${doc?.headlineFontWeight ?? "400"}; text-align:${doc?.headlineAlignment ?? "left"}; line-height:1.05; color:#1a1a1a;`}
        >
          {val("headline", "fr", "Quiet luxury for skin that looks luminous and composed.")}
        </p>
      </div>

      <div class="flex justify-end">
        <button type="submit" class="rounded-xl bg-charcoal px-6 py-2 text-xs font-medium text-cream transition hover:bg-charcoal/80">
          Save Typography
        </button>
      </div>
    </form>
  </div>

  <!-- ── TICKER PHRASES ───────────────────────────────────────── -->
  <div class="rounded-[1.5rem] border border-charcoal/10 bg-white/70 p-7 shadow-[0_8px_30px_rgba(31,37,34,0.06)] mb-6">
    <h2 class="mb-1 text-xs font-medium uppercase tracking-wider text-charcoal/50">Ticker Phrases</h2>
    <p class="mb-5 text-xs text-charcoal/40">Short phrases that scroll in the ticker bar below the hero. One phrase per line — no commas needed.</p>
    <form method="POST">
      <input type="hidden" name="_action" value="save-ticker" />
      <div class="admin-field">
        <label>Phrases (one per line)</label>
        <textarea
          name="tickerPhrases"
          rows={10}
          class="admin-input font-mono text-xs"
          placeholder={"Quiet Luxury\nFrench Ritual\nNatural Origin\nArgan & Rose\nSatin Finish"}
        >{(doc?.tickerPhrases as string[] | null | undefined)?.join("\n") ?? [
          "Formulated in Tunisia", "Argan & Rose", "Satin Finish",
          "Clean Performance", "Visible Glow", "Quiet Luxury",
          "French Ritual", "Natural Origin", "Barrier Comfort",
          "Cruelty-Free", "Tunisian Heritage", "Gold Standard",
        ].join("\n")}</textarea>
      </div>
      <div class="mt-4 flex items-center justify-between">
        <p class="text-xs text-charcoal/35">Changes appear instantly on the live site after saving.</p>
        <button type="submit" class="rounded-xl bg-charcoal px-6 py-2 text-xs font-medium text-cream transition hover:bg-charcoal/80">
          Save Ticker
        </button>
      </div>
    </form>
  </div>

  <!-- ── TEXT CONTENT ───────────────────────────────────────── -->
  <form method="POST" class="space-y-6">
    <input type="hidden" name="_action" value="save" />

    <!-- Eyebrow -->
    <div class="rounded-[1.5rem] border border-charcoal/10 bg-white/70 p-7 shadow-[0_8px_30px_rgba(31,37,34,0.06)]">
      <h2 class="mb-5 text-xs font-medium uppercase tracking-wider text-charcoal/50">Eyebrow Label</h2>
      <div class="admin-field max-w-sm">
        <label>Eyebrow (same for all languages)</label>
        <input name="eyebrow" class="admin-input" value={doc?.eyebrow ?? DEFAULTS.eyebrow} placeholder="e.g. Toucher Doux" />
      </div>
    </div>

    <!-- Localized tab cards -->
    {[
      {
        id: "headline",
        title: "Headline & Body",
        hint: "The large hero heading and supporting paragraph. Keep headline under 12 words.",
        fields: [
          { name: "headline", label: "Headline", type: "textarea", rows: 3 },
          { name: "body", label: "Body Text", type: "textarea", rows: 3 },
          { name: "cta1", label: "Primary Button", type: "input" },
          { name: "cta2", label: "Secondary Button", type: "input" },
        ],
      },
      {
        id: "trust",
        title: "Trust Points",
        hint: 'The 3 small items below the buttons, e.g. "Parisian restraint · Visible softness · Refined rituals"',
        fields: [
          { name: "trust1", label: "Trust Point 1", type: "input" },
          { name: "trust2", label: "Trust Point 2", type: "input" },
          { name: "trust3", label: "Trust Point 3", type: "input" },
        ],
      },
      {
        id: "callout",
        title: "Formula Callout",
        hint: "The text block in the top-right corner of the hero image.",
        fields: [
          { name: "formulaEyebrow", label: "Callout Label", type: "input" },
          { name: "formulaText", label: "Callout Text", type: "textarea", rows: 3 },
        ],
      },
      {
        id: "badge",
        title: "Product Badge Text",
        hint: "The floating card in the bottom-left of the hero image.",
        fields: [
          { name: "badgeLabel", label: "Badge Label (e.g. Signature Care)", type: "input" },
          { name: "badgeTitle", label: "Badge Title (e.g. Face Cream)", type: "input" },
        ],
      },
    ].map(({ id, title, hint, fields }) => (
      <div class="rounded-[1.5rem] border border-charcoal/10 bg-white/70 p-7 shadow-[0_8px_30px_rgba(31,37,34,0.06)]">
        <h2 class="mb-1 text-xs font-medium uppercase tracking-wider text-charcoal/50">{title}</h2>
        <p class="mb-6 text-xs text-charcoal/40">{hint}</p>

        <div class="flex gap-0 border-b border-charcoal/10 mb-7">
          <button type="button" data-tab-btn="fr" data-tab-group={id} class="admin-tab-btn active">🇫🇷 French</button>
          <button type="button" data-tab-btn="en" data-tab-group={id} class="admin-tab-btn">🇬🇧 English</button>
          <button type="button" data-tab-btn="ar" data-tab-group={id} class="admin-tab-btn">🇸🇦 Arabic</button>
        </div>

        {["fr", "en", "ar"].map((locale, li) => (
          <div data-tab-panel={locale} data-tab-group={id} class:list={["space-y-5", li > 0 && "hidden"]}>
            {fields.map(({ name, label, type, rows }) => (
              <div class="admin-field">
                <label>{label} ({locale.toUpperCase()})</label>
                {type === "textarea" ? (
                  <textarea
                    name={`${name}_${locale}`}
                    rows={rows ?? 3}
                    class="admin-input"
                    dir={locale === "ar" ? "rtl" : undefined}
                  >{val(name, locale, "")}</textarea>
                ) : (
                  <input
                    name={`${name}_${locale}`}
                    class="admin-input"
                    value={val(name, locale, "")}
                    dir={locale === "ar" ? "rtl" : undefined}
                  />
                )}
              </div>
            ))}
          </div>
        ))}
      </div>
    ))}

    <div class="flex justify-end">
      <button type="submit" class="rounded-xl bg-charcoal px-8 py-2.5 text-sm font-medium text-cream transition hover:bg-charcoal/80">
        Save Hero Text
      </button>
    </div>
  </form>
</AdminLayout>

<script>
  // ── Typography live preview ─────────────────────────────────
  const preview   = document.getElementById("typo-preview") as HTMLElement | null;
  const fontSel   = document.getElementById("typo-font")    as HTMLSelectElement | null;
  const sizeRange = document.getElementById("typo-size")    as HTMLInputElement | null;
  const sizeDisp  = document.getElementById("typo-size-display") as HTMLElement | null;
  const weightSel = document.getElementById("typo-weight")  as HTMLSelectElement | null;
  const alignGrp  = document.getElementById("align-group")  as HTMLElement | null;

  function updatePreview() {
    if (!preview) return;
    const ff = fontSel?.value ?? "'Playfair Display', Georgia, serif";
    const fs = sizeRange?.value ?? "7.5";
    const fw = weightSel?.value ?? "400";
    const fa = (alignGrp?.querySelector('input[name="headlineAlignment"]:checked') as HTMLInputElement | null)?.value ?? "left";
    if (sizeDisp) sizeDisp.textContent = `${fs}rem`;
    preview.style.fontFamily  = ff;
    preview.style.fontSize    = `clamp(1.6rem, 4vw, ${fs}rem)`;
    preview.style.fontWeight  = fw;
    preview.style.textAlign   = fa;
  }

  fontSel?.addEventListener("change", updatePreview);
  sizeRange?.addEventListener("input", updatePreview);
  weightSel?.addEventListener("change", updatePreview);
  alignGrp?.addEventListener("change", (e) => {
    const radio = e.target as HTMLInputElement;
    alignGrp.querySelectorAll("label").forEach((l) => {
      const active = l.querySelector("input")?.value === radio.value;
      l.classList.toggle("border-charcoal",   active);
      l.classList.toggle("bg-charcoal",       active);
      l.classList.toggle("text-cream",        active);
      l.classList.toggle("border-charcoal/15", !active);
      l.classList.toggle("bg-white",          !active);
      l.classList.toggle("text-charcoal/60",  !active);
    });
    updatePreview();
  });

  document.querySelectorAll<HTMLElement>("[data-tab-btn][data-tab-group]").forEach((btn) => {
    btn.addEventListener("click", () => {
      const locale = btn.dataset.tabBtn!;
      const group = btn.dataset.tabGroup!;
      document.querySelectorAll<HTMLElement>(`[data-tab-btn][data-tab-group="${group}"]`).forEach((b) =>
        b.classList.toggle("active", b === btn)
      );
      document.querySelectorAll<HTMLElement>(`[data-tab-panel][data-tab-group="${group}"]`).forEach((p) => {
        p.classList.toggle("hidden", p.dataset.tabPanel !== locale);
      });
    });
  });
</script>
