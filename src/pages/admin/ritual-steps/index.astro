---
export const prerender = false;
import AdminLayout from "@/layouts/AdminLayout.astro";
import { writeClient } from "@/sanity/write-client";

const items = await writeClient.fetch(`
  *[_type == "ritualStep"] | order(order asc) {
    _id, number, order,
    "title_fr": title[_key == "fr"][0].value,
    "copy_fr":  copy[_key == "fr"][0].value
  }
`);

const saved = Astro.url.searchParams.get("saved") === "1";
---

<AdminLayout title="Ritual Steps">
  <div class="mb-8 flex items-center justify-between">
    <div>
      <h1 class="font-display text-3xl text-charcoal">Ritual Steps</h1>
      <p class="mt-1 text-sm text-charcoal/55">{items.length} steps in the application ritual.</p>
    </div>
    <a href="/admin/dashboard" class="text-sm text-charcoal/50 hover:text-charcoal transition">← Dashboard</a>
  </div>

  {saved && (
    <div class="mb-6 rounded-xl border border-green-200 bg-green-50 px-5 py-3 text-sm text-green-700">
      Changes saved successfully.
    </div>
  )}

  <div class="space-y-4">
    {items.map((s: any) => (
      <div class="flex items-start justify-between rounded-[1.5rem] border border-charcoal/10 bg-white/70 px-7 py-5 shadow-[0_4px_20px_rgba(31,37,34,0.05)]">
        <div class="flex-1 pr-6">
          <span class="eyebrow">{s.number}</span>
          <p class="mt-1 font-medium text-charcoal">{s.title_fr}</p>
          <p class="mt-1 text-sm text-charcoal/60 line-clamp-2">{s.copy_fr}</p>
        </div>
        <a href={`/admin/ritual-steps/${s._id}`} class="shrink-0 text-sm font-medium text-gold hover:underline">Edit →</a>
      </div>
    ))}
  </div>
</AdminLayout>
