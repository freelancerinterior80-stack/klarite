---
export const prerender = false;
import AdminLayout from "@/layouts/AdminLayout.astro";
import { writeClient } from "@/sanity/write-client";

const { id } = Astro.params;
const loc = (arr: any[] | null | undefined, key: string) =>
  arr?.find((i: any) => i._key === key)?.value ?? "";

let error = "";
let success = "";

if (Astro.request.method === "POST") {
  const form = await Astro.request.formData();
  const action = form.get("_action") as string;

  try {
    if (action === "save-text") {
      await writeClient
        .patch(id!)
        .set({
          'title[_key=="fr"].value': form.get("title_fr") as string,
          'title[_key=="en"].value': form.get("title_en") as string,
          'title[_key=="ar"].value': form.get("title_ar") as string,
          'copy[_key=="fr"].value':  form.get("copy_fr") as string,
          'copy[_key=="en"].value':  form.get("copy_en") as string,
          'copy[_key=="ar"].value':  form.get("copy_ar") as string,
          number: form.get("number") as string,
        })
        .commit();
      success = "Text saved successfully.";
    }

    if (action === "upload-image") {
      const file = form.get("image") as File;
      if (!file || file.size === 0) {
        error = "Please select an image file.";
      } else {
        const buffer = Buffer.from(await file.arrayBuffer());
        const asset = await writeClient.assets.upload("image", buffer, {
          filename: file.name,
          contentType: file.type,
        });
        await writeClient
          .patch(id!)
          .set({
            image: {
              _type: "image",
              asset: { _type: "reference", _ref: asset._id },
              alt: (form.get("alt") as string) || "",
            },
          })
          .commit();
        success = "Image updated successfully.";
      }
    }
  } catch (e) {
    error = "Save failed. Please try again.";
  }
}

const doc = await writeClient.fetch(
  `*[_id == $id][0]{
    _id, number, order, title, copy,
    "imageUrl": image.asset->url,
    "imageAlt": image.alt
  }`,
  { id }
);

if (!doc) return Astro.redirect("/admin/ritual-steps");
---

<AdminLayout title={`Edit Ritual Step: ${doc.number}`}>
  <div class="mb-8">
    <a href="/admin/ritual-steps" class="text-sm text-charcoal/50 hover:text-charcoal transition">← Ritual Steps</a>
    <h1 class="mt-2 font-display text-3xl text-charcoal">Step {doc.number}</h1>
  </div>

  {error && (
    <div class="mb-6 rounded-xl border border-red-200 bg-red-50 px-5 py-3 text-sm text-red-700">{error}</div>
  )}
  {success && (
    <div class="mb-6 rounded-xl border border-green-200 bg-green-50 px-5 py-3 text-sm text-green-700">{success}</div>
  )}

  <!-- Image Upload -->
  <div class="mb-8 rounded-[1.5rem] border border-charcoal/10 bg-white/70 p-7 shadow-[0_8px_30px_rgba(31,37,34,0.06)]">
    <h2 class="mb-5 text-xs font-medium uppercase tracking-wider text-charcoal/50">Step Image</h2>

    {doc.imageUrl && (
      <div class="mb-6">
        <img
          src={`${doc.imageUrl}?w=600&auto=format`}
          alt={doc.imageAlt || "Step image"}
          class="h-56 w-full rounded-[1rem] object-cover shadow-sm"
        />
      </div>
    )}
    {!doc.imageUrl && (
      <div class="mb-6 flex h-40 w-full items-center justify-center rounded-[1rem] border-2 border-dashed border-charcoal/15 bg-cream/40 text-sm text-charcoal/40">
        No image uploaded yet
      </div>
    )}

    <form method="POST" enctype="multipart/form-data" class="space-y-4">
      <input type="hidden" name="_action" value="upload-image" />
      <div class="grid gap-4 sm:grid-cols-[1fr_auto]">
        <div class="admin-field">
          <label>New Image <span class="text-charcoal/40 font-normal">(JPEG, PNG or WebP)</span></label>
          <input type="file" name="image" accept="image/*" class="admin-input" required />
        </div>
        <div class="admin-field">
          <label>Alt Text</label>
          <input name="alt" class="admin-input" value={doc.imageAlt || ""} placeholder="Describe the image" />
        </div>
      </div>
      <div class="flex justify-end">
        <button type="submit" class="rounded-xl bg-charcoal px-7 py-2.5 text-sm font-medium text-cream transition hover:bg-charcoal/80">
          Upload Image
        </button>
      </div>
    </form>
  </div>

  <!-- Text Content -->
  <form method="POST" class="space-y-8">
    <input type="hidden" name="_action" value="save-text" />

    <div class="rounded-[1.5rem] border border-charcoal/10 bg-white/70 p-7 shadow-[0_8px_30px_rgba(31,37,34,0.06)]">
      <h2 class="mb-5 text-xs font-medium uppercase tracking-wider text-charcoal/50">Content</h2>
      <div class="flex gap-0 border-b border-charcoal/10 mb-7">
        <button type="button" data-tab-btn="fr" class="admin-tab-btn active">🇫🇷 French</button>
        <button type="button" data-tab-btn="en" class="admin-tab-btn">🇬🇧 English</button>
        <button type="button" data-tab-btn="ar" class="admin-tab-btn">🇸🇦 Arabic</button>
      </div>

      <div data-tab-panel="fr" class="space-y-5">
        <div class="admin-field">
          <label>Title (FR)</label>
          <input name="title_fr" class="admin-input" value={loc(doc.title, "fr")} required />
        </div>
        <div class="admin-field">
          <label>Instructions (FR)</label>
          <textarea name="copy_fr" rows="4" class="admin-input">{loc(doc.copy, "fr")}</textarea>
        </div>
      </div>
      <div data-tab-panel="en" class="hidden space-y-5">
        <div class="admin-field">
          <label>Title (EN)</label>
          <input name="title_en" class="admin-input" value={loc(doc.title, "en")} />
        </div>
        <div class="admin-field">
          <label>Instructions (EN)</label>
          <textarea name="copy_en" rows="4" class="admin-input">{loc(doc.copy, "en")}</textarea>
        </div>
      </div>
      <div data-tab-panel="ar" class="hidden space-y-5">
        <div class="admin-field">
          <label>Title (AR)</label>
          <input name="title_ar" class="admin-input" dir="rtl" value={loc(doc.title, "ar")} />
        </div>
        <div class="admin-field">
          <label>Instructions (AR)</label>
          <textarea name="copy_ar" rows="4" class="admin-input" dir="rtl">{loc(doc.copy, "ar")}</textarea>
        </div>
      </div>
    </div>

    <div class="rounded-[1.5rem] border border-charcoal/10 bg-white/70 p-7 shadow-[0_8px_30px_rgba(31,37,34,0.06)]">
      <h2 class="mb-5 text-xs font-medium uppercase tracking-wider text-charcoal/50">Step Label</h2>
      <div class="admin-field max-w-xs">
        <label>Step Number / Label</label>
        <input name="number" class="admin-input" value={doc.number} placeholder="01" />
      </div>
    </div>

    <div class="flex justify-end gap-4">
      <a href="/admin/ritual-steps" class="rounded-xl border border-charcoal/15 px-6 py-2.5 text-sm text-charcoal/60 hover:text-charcoal transition">Cancel</a>
      <button type="submit" class="rounded-xl bg-charcoal px-8 py-2.5 text-sm font-medium text-cream transition hover:bg-charcoal/80">Save Changes</button>
    </div>
  </form>
</AdminLayout>

<script>
  document.querySelectorAll("[data-tab-btn]").forEach((btn) => {
    btn.addEventListener("click", () => {
      const key = (btn as HTMLElement).dataset.tabBtn!;
      document.querySelectorAll("[data-tab-btn]").forEach((b) => b.classList.remove("active"));
      document.querySelectorAll("[data-tab-panel]").forEach((p) => p.classList.add("hidden"));
      btn.classList.add("active");
      document.querySelector(`[data-tab-panel="${key}"]`)?.classList.remove("hidden");
    });
  });
</script>
