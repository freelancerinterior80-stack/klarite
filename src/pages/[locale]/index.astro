<script>
  function initImageCycling() {
    document.querySelectorAll<HTMLElement>("[data-images]").forEach((el) => {
      if ((el as any).__galInit) return;
      (el as any).__galInit = true;
      try {
        const urls: string[] = JSON.parse(el.dataset.images!);
        if (!Array.isArray(urls) || urls.length < 2) return;
        const img = el.querySelector<HTMLImageElement>(".gallery-img");
        if (!img) return;
        let idx = 0;
        let timer: ReturnType<typeof setInterval>;
        el.addEventListener("mouseenter", () => {
          timer = setInterval(() => {
            idx = (idx + 1) % urls.length;
            img.src = urls[idx];
          }, 700);
        });
        el.addEventListener("mouseleave", () => {
          clearInterval(timer);
          idx = 0;
          img.src = urls[0];
        });
      } catch {}
    });
  }
  document.addEventListener("DOMContentLoaded", initImageCycling);
  document.addEventListener("astro:after-swap", initImageCycling);
</script>

<script define:vars={{ locale }}>
  (function () {
    var modal     = document.getElementById("enquire-modal");
    var backdrop  = document.getElementById("enquire-backdrop");
    var closeBtn  = document.getElementById("enquire-close");
    var doneBtn   = document.getElementById("enquire-done");
    var form      = document.getElementById("enquire-form");
    var formWrap  = document.getElementById("enquire-form-wrap");
    var success   = document.getElementById("enquire-success");
    var title     = document.getElementById("enquire-modal-title");
    var errorEl   = document.getElementById("enquire-error");
    var submitBtn = document.getElementById("enquire-submit");

    function openModal(productName, productSlug) {
      if (!modal) return;
      document.getElementById("enquire-product-name").value = productName;
      document.getElementById("enquire-product-slug").value = productSlug;
      document.getElementById("enquire-locale").value = locale;
      if (title) title.textContent = productName;
      formWrap.classList.remove("hidden");
      success.classList.add("hidden");
      if (form) form.reset();
      if (errorEl) errorEl.classList.add("hidden");
      document.getElementById("enquire-product-name").value = productName;
      document.getElementById("enquire-product-slug").value = productSlug;
      document.getElementById("enquire-locale").value = locale;
      modal.classList.remove("hidden");
      modal.classList.add("flex");
      document.body.style.overflow = "hidden";
    }

    function closeModal() {
      if (!modal) return;
      modal.classList.add("hidden");
      modal.classList.remove("flex");
      document.body.style.overflow = "";
    }

    function attachEnquireButtons() {
      document.querySelectorAll(".enquire-btn").forEach(function (btn) {
        if (btn.__enquireInit) return;
        btn.__enquireInit = true;
        btn.addEventListener("click", function () {
          openModal(btn.dataset.productName || "", btn.dataset.productSlug || "");
        });
      });
    }

    if (backdrop) backdrop.addEventListener("click", closeModal);
    if (closeBtn) closeBtn.addEventListener("click", closeModal);
    if (doneBtn)  doneBtn.addEventListener("click", closeModal);

    document.addEventListener("keydown", function (e) {
      if (e.key === "Escape") closeModal();
    });

    if (form) {
      form.addEventListener("submit", function (e) {
        e.preventDefault();
        if (submitBtn) { submitBtn.disabled = true; submitBtn.textContent = "Sending…"; }
        if (errorEl) errorEl.classList.add("hidden");

        fetch("/api/submit-inquiry", { method: "POST", body: new FormData(form) })
          .then(function (r) { return r.json(); })
          .then(function (data) {
            if (data.ok) {
              formWrap.classList.add("hidden");
              success.classList.remove("hidden");
            } else {
              if (errorEl) { errorEl.textContent = "Something went wrong. Please try again."; errorEl.classList.remove("hidden"); }
            }
          })
          .catch(function () {
            if (errorEl) { errorEl.textContent = "Network error. Please try again."; errorEl.classList.remove("hidden"); }
          })
          .finally(function () {
            if (submitBtn) { submitBtn.disabled = false; submitBtn.textContent = "Place Order"; }
          });
      });
    }

    attachEnquireButtons();
    document.addEventListener("astro:after-swap", attachEnquireButtons);
  })();
</script>
