---
export const prerender = false;
import BaseLayout from "@/layouts/BaseLayout.astro";
import BestSellers from "@/components/layout/BestSellers.astro";
import TrustBar from "@/components/layout/TrustBar.astro";
import { LOCALES, type Locale } from "@/i18n/config";
import { getTranslations } from "@/i18n";
import { client } from "@/sanity/client";
import { urlFor } from "@/sanity/image";
import { productsQuery, testimonialsQuery, ritualStepsQuery } from "@/sanity/queries";

export function getStaticPaths() {
  return LOCALES.map(locale => ({ params: { locale } }));
}

const { locale } = Astro.params as { locale: Locale };
const t = getTranslations(locale);

const seoQuery = `*[_id == "seoSettings"][0]{
  keywords, canonicalUrl, twitterHandle, googleAnalyticsId, titleSuffix,
  "title": homepageTitle[_key == $locale][0].value,
  "description": homepageDescription[_key == $locale][0].value,
  "ogImageUrl": ogImage.asset->url
}`;

const heroQuery = `*[_id == "heroSettings"][0]{
  eyebrow,
  mediaType,
  "heroImageUrl":    heroImage.asset->url,
  "heroVideoFileUrl": heroVideoFile.asset->url,
  heroVideoUrl,
  "badgeImageUrl":  badgeImage.asset->url,
  "headline":       headline[_key == $locale][0].value,
  "body":           body[_key == $locale][0].value,
  "cta1":           cta1Label[_key == $locale][0].value,
  "cta2":           cta2Label[_key == $locale][0].value,
  "trust1":         trust1[_key == $locale][0].value,
  "trust2":         trust2[_key == $locale][0].value,
  "trust3":         trust3[_key == $locale][0].value,
  "formulaEyebrow": formulaEyebrow[_key == $locale][0].value,
  "formulaText":    formulaText[_key == $locale][0].value,
  "badgeLabel":     badgeLabel[_key == $locale][0].value,
  "badgeTitle":     badgeTitle[_key == $locale][0].value,
  tickerPhrases,
  headlineFontFamily,
  headlineFontSize,
  headlineFontWeight,
}`;

const [products, testimonials, ritualSteps, seoData, heroData, brandSettings] = await Promise.all([
  client.fetch(productsQuery, { locale }),
  client.fetch(testimonialsQuery, { locale }),
  client.fetch(ritualStepsQuery, { locale }),
  client.fetch(seoQuery, { locale }),
  client.fetch(heroQuery, { locale }),
  client.fetch(`*[_type == "brandSettings"][0]{ orderBtnLabel, orderBtnBg, orderBtnText }`),
]);

const orderBtnLabel: string = brandSettings?.orderBtnLabel || "Order Now";
const orderBtnBg: string    = brandSettings?.orderBtnBg    || "#1c1c1c";
const orderBtnText: string  = brandSettings?.orderBtnText  || "#f6f3ee";

// Resolve video URL: uploaded file takes priority over external URL
const heroVideoSrc = heroData?.heroVideoFileUrl || heroData?.heroVideoUrl || null;

// Fallbacks so the hero works before admin fills it in
const hero = {
  mediaType:      heroData?.mediaType      || "image",
  heroImageUrl:   heroData?.heroImageUrl   || null,
  videoSrc:       heroVideoSrc,
  badgeImageUrl:  heroData?.badgeImageUrl  || null,
  eyebrow:        heroData?.eyebrow        || "Toucher Doux",
  headline:       heroData?.headline       || "Quiet luxury for skin that looks luminous and composed.",
  body:           heroData?.body           || "KLARITE distills the ritual of French beauty into calm, high-performance formulas with clinical clarity and a soft editorial finish.",
  cta1:           heroData?.cta1           || t.nav.shopCta,
  cta2:           heroData?.cta2           || t.nav.skinQuiz,
  trust1:         heroData?.trust1         || "Parisian restraint",
  trust2:         heroData?.trust2         || "Visible softness",
  trust3:         heroData?.trust3         || "Refined daily rituals",
  formulaEyebrow: heroData?.formulaEyebrow || "Hero Formula",
  formulaText:    heroData?.formulaText    || "Cushion-soft hydration with a satin glow.",
  badgeLabel:     heroData?.badgeLabel     || "Signature Care",
  badgeTitle:     heroData?.badgeTitle     || "Face Cream",
  headlineFontFamily: heroData?.headlineFontFamily || "'Playfair Display', Georgia, serif",
  headlineFontSize:   heroData?.headlineFontSize   || "7.5",
  headlineFontWeight: heroData?.headlineFontWeight || "400",
};

const defaultTicker = [
  "Formulated in Tunisia", "Argan & Rose", "Satin Finish",
  "Clean Performance", "Visible Glow", "Quiet Luxury",
  "French Ritual", "Natural Origin", "Barrier Comfort",
  "Cruelty-Free", "Tunisian Heritage", "Gold Standard",
];
const tickerPhrases: string[] =
  heroData?.tickerPhrases?.length ? heroData.tickerPhrases : defaultTicker;

// ── Dynamic product helpers ───────────────────────────────────
const signatureProducts: any[] = products.slice(0, 3);

function getGalleryUrls(product: any, width = 900): string[] {
  const main = product?.image?.asset
    ? urlFor(product.image).width(width).format("webp").url()
    : null;
  const extras = (product?.images ?? [])
    .filter((img: any) => img?.asset)
    .map((img: any) => urlFor(img).width(width).format("webp").url());
  return [main, ...extras].filter(Boolean) as string[];
}

const benefits = [
  {
    title: "Clarity",
    copy: "Gentle cleansing and intelligent hydration refine the look of texture so skin appears fresh, composed, and balanced."
  },
  {
    title: "Softness",
    copy: "Silken creams and weightless lotions leave behind a supple finish that feels quiet, comforting, and expensive."
  },
  {
    title: "Radiance",
    copy: "Each formula is designed to return light to the skin with a satin glow rather than a glossy, overworked shine."
  }
];

---

<BaseLayout
  title={seoData?.title || "KLARITÉ — Beauté Raffinée"}
  description={seoData?.description || "French-inspired beauty, thoughtfully formulated."}
  locale={locale}
  seo={{
    keywords: seoData?.keywords,
    canonicalUrl: seoData?.canonicalUrl,
    twitterHandle: seoData?.twitterHandle,
    googleAnalyticsId: seoData?.googleAnalyticsId,
    ogImageUrl: seoData?.ogImageUrl,
    titleSuffix: seoData?.titleSuffix,
  }}
>
  <Fragment set:html={`<style>:root{--order-btn-bg:${orderBtnBg};--order-btn-text:${orderBtnText};}</style>`} />

  <!-- ══════════════════════════════════════════════════════════════
       CAMPAIGN BANNER — shown when a campaign is active
       ══════════════════════════════════════════════════════════════ -->
  <div id="campaign-banner" class="campaign-slider hidden" aria-label="Promotional campaign" role="region"></div>

  <!-- ══════════════════════════════════════════════════════════════
       HERO — full-viewport, two-column editorial layout
       ══════════════════════════════════════════════════════════════ -->
  <section
    id="hero-section"
    class="section-band section-band--first section-band--cream relative flex min-h-[100dvh] flex-col justify-center px-4 pb-16 pt-10 sm:px-6 lg:px-10 lg:pb-20 lg:pt-14"
  >
    <!-- Ambient background glow -->
    <div class="pointer-events-none absolute inset-0 overflow-hidden">
      <div class="absolute right-[5%] top-[8%] h-[50vw] w-[50vw] max-h-[640px] max-w-[640px] rounded-full bg-gold/10 blur-[120px]"></div>
      <div class="absolute left-[-5%] bottom-[10%] h-[40vw] w-[40vw] max-h-[480px] max-w-[480px] rounded-full bg-sage-300/14 blur-[100px]"></div>
    </div>

    <div class="relative mx-auto grid w-full max-w-[90rem] gap-10 lg:grid-cols-[1fr_1.08fr] lg:items-center lg:gap-16">

      <!-- LEFT — text column -->
      <div data-reveal>
        <p class="eyebrow">{hero.eyebrow}</p>

        <h1
          class="section-title mt-6 text-charcoal"
          style={`font-family:${hero.headlineFontFamily}; font-size:clamp(3.2rem, 7vw, ${hero.headlineFontSize}rem); font-weight:${hero.headlineFontWeight}; max-width:12ch; line-height:1.04;`}
        >
          {hero.headline}
        </h1>

        <p class="mt-8 max-w-[30rem] text-[1.02rem] leading-[1.85] text-stone sm:text-[1.08rem]">
          {hero.body}
        </p>

        <!-- Social proof -->
        <div class="mt-7 flex items-center gap-3">
          <div class="flex gap-0.5 leading-none text-gold" style="font-size:1rem;" aria-hidden="true">★★★★★</div>
          <span class="text-[0.7rem] text-charcoal/55">4.9 / 5 &nbsp;·&nbsp; 200+ clientes satisfaites</span>
        </div>

        <div class="mt-8 flex flex-col gap-4 sm:flex-row">
          <a href="#signature-products" class="cta-primary">{hero.cta1}</a>
          <a href="#skin-quiz" class="cta-secondary">{hero.cta2}</a>
        </div>

        <ul class="mt-14 grid gap-4 border-t border-charcoal/8 pt-8 text-[0.67rem] uppercase tracking-[0.34em] text-stone/70 sm:grid-cols-3">
          <li>{hero.trust1}</li>
          <li>{hero.trust2}</li>
          <li>{hero.trust3}</li>
        </ul>
      </div>

      <!-- RIGHT — hero visual -->
      <div class="relative" style="min-height: clamp(36rem, 70vh, 56rem);" data-reveal>

        <!-- Outer glow orbs (outside the glass) -->
        <div class="hero-glow pointer-events-none left-[4%] top-[8%] h-[18rem] w-[18rem] sm:h-[24rem] sm:w-[24rem] lg:h-[28rem] lg:w-[28rem]"></div>
        <div class="hero-glow hero-glow--gold pointer-events-none right-[2%] top-[6%] h-[20rem] w-[20rem] sm:h-[26rem] sm:w-[26rem] lg:h-[32rem] lg:w-[32rem]"></div>

        <!-- Glass container -->
        <div class="hero-glass relative flex h-full items-end justify-center overflow-hidden rounded-[2rem] sm:rounded-[2.8rem]">
          <!-- Inner light layering -->
          <div class="absolute inset-0 bg-[linear-gradient(145deg,rgba(255,252,248,0.9),rgba(252,248,242,0.38))]"></div>
          <div class="absolute left-1/2 top-[6%] h-[60%] w-[80%] -translate-x-1/2 rounded-full bg-white/85 blur-[56px]"></div>
          <div class="absolute left-1/2 top-[12%] h-[50%] w-[64%] -translate-x-1/2 rounded-full bg-sage-300/22 blur-[90px]"></div>
          <div class="absolute left-1/2 top-[14%] h-[46%] w-[56%] -translate-x-1/2 rounded-full bg-gold/18 blur-[110px]"></div>
          <!-- Ground shadow -->
          <div class="absolute inset-x-[10%] bottom-[6%] h-14 rounded-full bg-charcoal/[0.13] blur-[44px]"></div>
          <div class="absolute inset-x-[24%] bottom-[7%] h-6 rounded-full bg-white/70 blur-[22px]"></div>

          <!-- Main hero media: video or image -->
          {hero.mediaType === "video" && hero.videoSrc ? (
            <video
              autoplay
              muted
              loop
              playsinline
              class="relative z-10 w-full object-cover drop-shadow-[0_44px_88px_rgba(28,28,28,0.18)]"
              style="height: clamp(28rem, 55vh, 50rem);"
            >
              <source src={hero.videoSrc} />
            </video>
          ) : (
            <img
              src={hero.heroImageUrl
                ? `${hero.heroImageUrl}?w=900&auto=format`
                : (products[0]?.image?.asset ? urlFor(products[0].image).width(900).format("webp").url() : "")}
              width={900}
              alt="KLARITÉ hero product"
              class="relative z-10 w-auto max-w-full object-contain object-center drop-shadow-[0_44px_88px_rgba(28,28,28,0.24)]"
              style="height: clamp(28rem, 55vh, 50rem); padding-bottom: 2rem;"
              loading="eager"
              decoding="async"
              data-float
              data-float-distance="16"
              data-float-duration="11"
              data-scale-in
            />
          )}

          <!-- Floating product badge (bottom-left) -->
          <aside
            class="absolute bottom-5 left-5 z-20 w-[10.5rem] rounded-[1.75rem] border border-white/70 bg-[rgba(255,252,249,0.92)] p-3 shadow-[0_20px_56px_rgba(28,28,28,0.12)] backdrop-blur-2xl sm:bottom-7 sm:left-7 sm:w-[12rem] sm:p-4"
            data-float
            data-float-distance="7"
            data-float-duration="14"
          >
            <img
              src={hero.badgeImageUrl
                ? `${hero.badgeImageUrl}?w=400&h=400&fit=crop&auto=format`
                : "/images/products/creme-visage-box.jpeg"}
              width="400"
              height="400"
              alt="KLARITÉ product"
              class="h-28 w-full rounded-[1.3rem] object-cover object-center sm:h-36"
              loading="lazy"
              decoding="async"
            />
            <p class="mt-3 text-[0.65rem] uppercase tracking-[0.26em] text-charcoal/48">{hero.badgeLabel}</p>
            <p class="mt-1.5 font-display text-[1.15rem] leading-5 text-charcoal">{hero.badgeTitle}</p>
          </aside>

          <!-- Formula callout (top-right) — dark pill badge -->
          <div class="absolute right-5 top-5 z-20 max-w-[13rem] rounded-[1.2rem] border border-white/15 bg-[rgba(28,28,28,0.88)] px-4 py-3 shadow-[0_12px_32px_rgba(28,28,28,0.28)] backdrop-blur-xl sm:right-7 sm:top-7">
            <p class="text-[0.55rem] uppercase tracking-[0.28em] text-cream/45">{hero.formulaEyebrow}</p>
            <p class="mt-2 font-display text-[1.1rem] leading-[1.25] tracking-[-0.01em] text-cream">
              {hero.formulaText}
            </p>
          </div>
        </div>

        <!-- Scroll indicator -->
        <div class="absolute -bottom-8 left-1/2 hidden -translate-x-1/2 flex-col items-center gap-2 lg:flex">
          <div class="h-10 w-px bg-gradient-to-b from-charcoal/20 to-transparent"></div>
          <p class="text-[0.6rem] uppercase tracking-[0.36em] text-charcoal/30">Scroll</p>
        </div>
      </div>

    </div>
  </section>

  <!-- Campaign banner client script -->
  <script define:vars={{ locale }}>
    (function () {
      if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;

      fetch("/api/active-campaign.json?locale=" + locale)
        .then(function (r) { return r.json(); })
        .then(function (campaign) {
          if (!campaign || !Array.isArray(campaign.slides) || campaign.slides.length === 0) return;

          var slides = campaign.slides.filter(function (s) { return s.imageUrl; });
          if (slides.length === 0) return;

          var banner = document.getElementById("campaign-banner");
          var hero = document.getElementById("hero-section");
          if (!banner || !hero) return;

          // Apply height + width modifier classes
          banner.classList.add("campaign-slider--" + (campaign.bannerSize || "large"));
          banner.classList.add("campaign-slider--width-" + (campaign.bannerWidth || "full"));

          // Build slides HTML
          var slidesHtml = slides.map(function (slide, i) {
            var opacity = typeof slide.overlayOpacity === "number" ? slide.overlayOpacity / 100 : 0.4;
            return [
              '<div class="campaign-slide' + (i === 0 ? " active" : "") + '"',
              ' style="background-image:url(\'' + slide.imageUrl + '?w=1600&auto=format\')">',
              '<div class="campaign-slide__overlay" style="background:rgba(0,0,0,' + opacity + ');"></div>',
              '<div class="campaign-slide__content">',
              '<p class="campaign-slide__eyebrow">KLARITÉ</p>',
              slide.headline ? '<h2 class="campaign-slide__headline">' + slide.headline + '</h2>' : '',
              slide.subtext  ? '<p class="campaign-slide__subtext">' + slide.subtext + '</p>' : '',
              slide.ctaLabel && slide.ctaUrl
                ? '<a href="' + slide.ctaUrl + '" class="cta-primary">' + slide.ctaLabel + '</a>'
                : '',
              '</div>',
              '</div>',
            ].join("");
          }).join("");

          // Nav arrows (only if >1 slide)
          var navHtml = slides.length > 1 ? [
            '<button class="campaign-nav-btn campaign-nav-prev" aria-label="Previous slide">',
            '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>',
            '</button>',
            '<button class="campaign-nav-btn campaign-nav-next" aria-label="Next slide">',
            '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>',
            '</button>',
          ].join("") : "";

          // Dots
          var dotsHtml = slides.length > 1
            ? '<div class="campaign-dots">' + slides.map(function (_, i) {
                return '<button class="campaign-dot' + (i === 0 ? " active" : "") + '" aria-label="Slide ' + (i + 1) + '"></button>';
              }).join("") + '</div>'
            : "";

          banner.innerHTML = slidesHtml + navHtml + dotsHtml;

          // Show campaign, hide hero
          hero.classList.add("hidden");
          banner.classList.remove("hidden");

          // Slider logic
          if (slides.length <= 1) return;

          var current = 0;
          var slideEls = banner.querySelectorAll(".campaign-slide");
          var dotEls   = banner.querySelectorAll(".campaign-dot");

          function goTo(idx) {
            slideEls[current].classList.remove("active");
            dotEls[current].classList.remove("active");
            current = (idx + slides.length) % slides.length;
            slideEls[current].classList.add("active");
            dotEls[current].classList.add("active");
          }

          var timer = setInterval(function () { goTo(current + 1); }, 5000);

          banner.querySelector(".campaign-nav-next").addEventListener("click", function () {
            clearInterval(timer);
            goTo(current + 1);
            timer = setInterval(function () { goTo(current + 1); }, 5000);
          });
          banner.querySelector(".campaign-nav-prev").addEventListener("click", function () {
            clearInterval(timer);
            goTo(current - 1);
            timer = setInterval(function () { goTo(current + 1); }, 5000);
          });
          dotEls.forEach(function (dot, i) {
            dot.addEventListener("click", function () {
              clearInterval(timer);
              goTo(i);
              timer = setInterval(function () { goTo(current + 1); }, 5000);
            });
          });
        })
        .catch(function () { /* silently fall through to hero */ });
    })();
  </script>

  <!-- ── Trust bar ─────────────────────────────────────────────────── -->
  <TrustBar trustPoints={[
    hero.trust1 || "Artisanat Tunisien",
    hero.trust2 || "Formules Naturelles",
    hero.trust3 || "Cruelty-Free",
    "Sans Parabènes",
  ]} />

  <!-- ── Marquee ticker ─────────────────────────────────────────────── -->
  <div class="marquee-outer section-band border-y border-charcoal/8 bg-white py-5">
    <div class="marquee-track items-center">
      {[...tickerPhrases, ...tickerPhrases].flatMap((item: string) => [
        <span class="eyebrow shrink-0 whitespace-nowrap px-10 text-charcoal/60">{item}</span>,
        <span class="shrink-0 text-gold flex-none leading-none" style="font-size:0.55rem;" aria-hidden="true">✦</span>,
      ])}
    </div>
  </div>

  <!-- ── Brand statement (dark) ─────────────────────────────────────── -->
  <section class="section-band section-band--dark relative px-6 py-16 sm:px-10 sm:py-20 lg:py-28">
    <!-- Decorative oversized quotation mark -->
    <div class="pointer-events-none absolute -top-6 left-[3%] select-none font-display leading-none text-white/[0.04]" style="font-size: clamp(14rem, 22vw, 24rem);" aria-hidden="true">&ldquo;</div>
    <div class="relative mx-auto max-w-[90rem]">
      <p class="eyebrow text-cream/35 mb-8" data-reveal>The KLARITÉ Promise</p>
      <div class="mb-8 w-10 border-t border-gold/40" data-reveal></div>
      <h2
        class="section-title text-cream"
        style="font-size: clamp(3.2rem, 8.5vw, 9.5rem); max-width: 18ch;"
        data-reveal
      >
        Skin that speaks before you do.
      </h2>
      <div class="mt-8 w-10 border-t border-gold/40" data-reveal></div>
      <p class="mt-5 text-[0.62rem] uppercase tracking-[0.4em] text-cream/28" data-reveal>— La promesse KLARITÉ</p>
      <div class="mt-14 grid gap-8 border-t border-white/10 pt-14 sm:grid-cols-3" data-reveal>
        <p class="text-[0.94rem] leading-[1.8] text-cream/50 sm:col-span-2 max-w-[44rem]">
          Every KLARITÉ formula is an act of restraint — nothing added without purpose, nothing removed without care. The result is skin that looks composed, luminous, and effortlessly itself.
        </p>
        <div class="flex items-end justify-start sm:justify-end">
          <a href="#signature-products" class="cta-secondary border-white/20 text-cream/80 hover:border-gold/40 hover:text-cream">
            Shop Collection
          </a>
        </div>
      </div>
    </div>
  </section>

  <section id="signature-products" class="section-band section-band--white px-4 py-36 sm:px-6 lg:px-10 lg:py-40">
    <div class="mx-auto max-w-[90rem]">
      <div class="flex flex-col gap-6 lg:flex-row lg:items-end lg:justify-between" data-reveal>
        <div>
          <p class="eyebrow">Signature Products</p>
          <h2
            class="section-title mt-7 text-charcoal"
            style="font-size: clamp(2.8rem, 6.5vw, 7rem); max-width: 14ch;"
          >
            Three essentials that define the KLARITÉ wardrobe.
          </h2>
        </div>
        <a href="#collection-grid" class="cta-primary mb-1 self-start lg:self-auto shrink-0">View Full Collection</a>
      </div>

      <div class="mt-20 grid gap-10 xl:grid-cols-3">
        {signatureProducts.filter(Boolean).map((product: any) => {
          const galleryUrls = getGalleryUrls(product, 800);
          return (
            <article class="editorial-card group flex flex-col" data-reveal>
              <!-- Gold accent bar at card top -->
              <div class="absolute inset-x-0 top-0 z-10 h-[3px] bg-gradient-to-r from-transparent via-gold/50 to-transparent" aria-hidden="true"></div>
              <div
                class="editorial-media relative"
                data-images={galleryUrls.length > 1 ? JSON.stringify(galleryUrls) : undefined}
              >
                {product.image?.asset ? (
                  <img
                    src={urlFor(product.image).width(800).format("webp").url()}
                    width={800}
                    alt={product.image?.alt ?? product.name}
                    class="gallery-img h-[29rem] w-full object-cover sm:h-[38rem]"
                    loading="lazy"
                    decoding="async"
                    data-scale-in
                  />
                ) : (
                  <div class:list={["h-[29rem] w-full sm:h-[38rem] bg-gradient-to-br", product.accent ?? "from-stone-100 to-stone-200"]}></div>
                )}
                <div class="card-overlay">
                  <span class="rounded-full bg-charcoal/85 px-5 py-2 text-[0.65rem] uppercase tracking-[0.28em] text-cream backdrop-blur-sm">
                    Discover →
                  </span>
                </div>
              </div>

              <div class="mt-8 flex flex-1 flex-col">
                <div class="flex items-start justify-between gap-4">
                  <div>
                    <p class="eyebrow">{product.category}</p>
                    <h3 class="mt-4 font-display text-[2.1rem] leading-[1.05] tracking-[-0.02em] text-charcoal sm:text-[2.6rem]">
                      {product.name}
                    </h3>
                    {product.notes?.[0] && (
                      <p class="mt-2 text-[0.72rem] uppercase tracking-[0.22em] text-stone/80">{product.notes[0]}</p>
                    )}
                  </div>
                  <span class="mt-1 shrink-0 font-display text-[1.4rem] text-charcoal/40">{product.price}</span>
                </div>

                <p class="mt-5 flex-1 max-w-[24rem] text-[0.94rem] leading-[1.75] text-stone">{product.shortDesc}</p>

              <button
                class="enquire-btn cta-primary mt-6 self-start"
                data-product-name={product.name ?? ""}
                data-product-slug={product.slug?.current ?? product.slug ?? ""}
                type="button"
              >
                {orderBtnLabel}
              </button>
              </div>
            </article>
          );
        })}
      </div>
    </div>
  </section>

  <!-- ── Section divider ─────────────────────────────────────────── -->
  <div class="section-band section-band--white">
    <div class="section-divider mx-auto max-w-[90rem] px-6" aria-hidden="true">
      <span></span>⟡<span></span>
    </div>
  </div>

